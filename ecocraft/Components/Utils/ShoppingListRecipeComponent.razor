@using ecocraft.Models
@using ecocraft.Services
@inject ShoppingListDataService ShoppingListDataService
@inject LocalizationService LocalizationService
@inject ServerDataService ServerDataService

<MudStack Class="@($"pl-{Indent}")">
    <MudStack Row>
        <MudText>@UserRecipe.Recipe.Name</MudText>
        <MudNumericField T="int"
                         Value="UserRecipe.RoundFactor"
                         ValueChanged="v => OnQuantityToCraftChanged(v)"
                         Format="0"
                         Immediate />
        <MudIconButton Icon="@MDIIcons.Filled.Close"
                       Size="Size.Small"
                       OnClick="() => RemoveShoppingListRecipe()" />
    </MudStack>

    @foreach (var product in UserRecipe.Recipe.Elements.Where(e => !e.IsIngredient()))
    {
        <MudStack Row>
            <EcoIcon Item="product.ItemOrTag" />
            <MudText Typo="Typo.body2">@LocalizationService.GetTranslation(product.ItemOrTag)</MudText>
            <MudNumericField T="decimal"
                             Class="rectangle-input"
                             Style="width: 111px;"
                             ReadOnly
                             HideSpinButtons
                             Value="product.CurrentUserElement!.SLQuantity"
                             Format="0"
                             Variant="Variant.Outlined"/>
        </MudStack>
    }

    <MudDivider />

    @foreach (var ingredient in UserRecipe.Recipe.Elements.Where(e => e.IsIngredient()))
    {
        var childRecipes = UserRecipe.ChildrenUserRecipes.Where(c => c.Recipe.Elements.Any(e => e.ItemOrTag == ingredient.ItemOrTag && !e.IsIngredient()));

        <MudStack Row>
            <EcoIcon Item="ingredient.ItemOrTag" />
            <MudText Typo="Typo.body2">@LocalizationService.GetTranslation(ingredient.ItemOrTag)</MudText>
            <MudNumericField T="decimal"
                             Class="rectangle-input"
                             Style="width: 111px;"
                             ReadOnly
                             HideSpinButtons
                             Value="ingredient.CurrentUserElement!.SLRemainingQuantity"
                             Format="0"
                             Variant="Variant.Outlined"/>
            @if (!childRecipes.Any())
            {
                <MudIconButton Icon="@MDIIcons.Filled.Plus"
                               Size="Size.Small"
                               OnClick="() => AddChildRecipe(ingredient, ingredient.CurrentUserElement.SLRemainingQuantity)"/>
            }
        </MudStack>

        @foreach (var childRecipe in childRecipes)
        {
            <ShoppingListRecipeComponent Calculate="Calculate" SelectedShoppingList="SelectedShoppingList" UserRecipe="childRecipe" Indent="@(Indent + 4)" />
        }
    }
</MudStack>

@code {
    [Parameter] public required DataContext SelectedShoppingList { get; set; }
    [Parameter] public required UserRecipe UserRecipe { get; set; }
    [Parameter] public EventCallback Calculate { get; set; }
    [Parameter] public int Indent { get; set; }

    private async Task OnQuantityToCraftChanged(int value)
    {
        UserRecipe.RoundFactor = value;
        await Calculate.InvokeAsync();
    }

    private async Task RemoveShoppingListRecipe()
    {
        ShoppingListDataService.RemoveUserRecipe(SelectedShoppingList, UserRecipe);
        await Calculate.InvokeAsync();
    }

    private async Task AddChildRecipe(Element element, decimal quantityGoal)
    {
        // TODO: allow to select a recipe
        var recipe = ServerDataService.Recipes.FirstOrDefault(r => r.Elements.Any(e => e.Index == 0 && e.IsProduct() && e.ItemOrTag == element.ItemOrTag));

        if (recipe is not null)
        {
            var quantityToCraft = Math.Ceiling(quantityGoal / recipe.Elements.First(e => e.ItemOrTag == element.ItemOrTag && e.IsProduct() && e.Index == 0).Quantity.GetDynamicValue());

            ShoppingListDataService.AddUserRecipe(SelectedShoppingList, recipe, UserRecipe, (int)quantityToCraft);
            await Calculate.InvokeAsync();
        }
    }
}
