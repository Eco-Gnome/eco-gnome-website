@page "/guide/shopping-list"
@using ecocraft.Extensions
@using ecocraft.Services
@inject LocalizationService LocalizationService

<PageTitle>@LocalizationService.GetTranslation("ShoppingListGuide.PageTitle") - Eco Gnome</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
    <MudStack Spacing="4">
        <section class="guide-hero">
            <MudStack Spacing="2">
                <MudText Typo="Typo.overline" Color="Color.Primary">@LocalizationService.GetTranslation("Guide.Eyebrow")</MudText>
                <MudText Typo="Typo.h3">@LocalizationService.GetTranslation("ShoppingListGuide.Title")</MudText>
                <MudText Typo="Typo.body1">@LocalizationService.GetTranslation("ShoppingListGuide.Intro")</MudText>
                <MudStack Row Spacing="2" Class="flex-wrap">
                    <MudButton Href="/guide" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.HelpOutline">
                        @LocalizationService.GetTranslation("Guide.BackToGuide")
                    </MudButton>
                    <MudButton Href="/shopping-list" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@MDIIcons.Outline.Cart">
                        @LocalizationService.GetTranslation("ShoppingListGuide.OpenTool")
                    </MudButton>
                </MudStack>
            </MudStack>
        </section>

        <MudPaper Elevation="0" Class="guide-panel pa-4">
            <MudStack Spacing="3">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@MDIIcons.Filled.TableOfContents" Color="Color.Primary"/>
                    <MudText Typo="Typo.h5">@LocalizationService.GetTranslation("ShoppingListGuide.Workflow.Title")</MudText>
                </MudStack>
                <MudGrid>
                    @foreach (var step in Steps)
                    {
                        <MudItem xs="12" md="6" lg="3">
                            <MudStack Spacing="1" Class="guide-step">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@step.Icon" Color="Color.Primary"/>
                                    <MudText Typo="Typo.h6">@LocalizationService.GetTranslation(step.TitleKey)</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation(step.BodyKey)</MudText>
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private static readonly GuideItem[] Steps =
    [
        new("ShoppingListGuide.Workflow.Context.Title", "ShoppingListGuide.Workflow.Context.Body", MDIIcons.Filled.Tab),
        new("ShoppingListGuide.Workflow.Setup.Title", "ShoppingListGuide.Workflow.Setup.Body", MDIIcons.Filled.Tune),
        new("ShoppingListGuide.Workflow.Recipes.Title", "ShoppingListGuide.Workflow.Recipes.Body", Icons.Material.Filled.AccountTree),
        new("ShoppingListGuide.Workflow.Expand.Title", "ShoppingListGuide.Workflow.Expand.Body", Icons.Material.Filled.AutoFixHigh)
    ];

    private sealed record GuideItem(string TitleKey, string BodyKey, string Icon);
}
