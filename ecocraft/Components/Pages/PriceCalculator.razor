    private async Task OnLevelChanged(UserSkill userSkill, int newLevel)
    {
        if (userSkill.Level == newLevel) return;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            var isIncrease = newLevel - userSkill.Level > 0;
            userSkill.Level = newLevel;
            UserSkillDbService.UpdateLevel(context, userSkill);

            if (_selectedDataContext!.UserSettings.First().OnlyLevelAccessibleRecipes)
            {
                UserServerDataService.UserSkillLevelChange(context, _selectedDataContext!, ContextService.CurrentServerData!, userSkill, isIncrease);
            }

            if (!isIncrease)
            {
                foreach (var talent in userSkill.Skill!.Talents.Where(t => t.GetCurrentUserTalent(_selectedDataContext!) is not null && newLevel < t.Level))
                {
                    UserServerDataService.RemoveUserTalent(context, talent.GetCurrentUserTalent(_selectedDataContext!)!);
                }
            }

            return Task.CompletedTask;
        });

        await Calculate();
    }

