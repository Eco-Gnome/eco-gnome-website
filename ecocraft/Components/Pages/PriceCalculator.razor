    private Task OnLevelChanged(UserSkill userSkill, int newLevel)
    {
        if (userSkill.Level == newLevel) return Task.CompletedTask;

        var previousLevel = userSkill.Level;
        userSkill.Level = newLevel;
        _ = PersistSkillLevelChangeDebounced(userSkill, previousLevel, newLevel);
        return Task.CompletedTask;
    }

    private async Task PersistSkillLevelChangeDebounced(UserSkill userSkill, int previousLevel, int newLevel)
    {
        try
        {
            CancellationTokenSource currentDebounceCts;
            lock (_skillLevelSaveDebounceLock)
            {
                if (!_lastPersistedSkillLevelBySkillId.ContainsKey(userSkill.Id))
                {
                    _lastPersistedSkillLevelBySkillId[userSkill.Id] = previousLevel;
                }

                _pendingSkillLevelBySkillId[userSkill.Id] = newLevel;
                currentDebounceCts = new CancellationTokenSource();

                if (_skillLevelSaveDebounceBySkillId.TryGetValue(userSkill.Id, out var previousDebounceCts))
                {
                    previousDebounceCts.Cancel();
                    previousDebounceCts.Dispose();
                }

                _skillLevelSaveDebounceBySkillId[userSkill.Id] = currentDebounceCts;
            }

            try
            {
                await Task.Delay(SkillLevelSaveDebounceMs, currentDebounceCts.Token);
            }
            catch (TaskCanceledException)
            {
                return;
            }
            finally
            {
                lock (_skillLevelSaveDebounceLock)
                {
                    if (_skillLevelSaveDebounceBySkillId.TryGetValue(userSkill.Id, out var trackedCts)
                        && ReferenceEquals(trackedCts, currentDebounceCts))
                    {
                        _skillLevelSaveDebounceBySkillId.Remove(userSkill.Id);
                    }
                }

                currentDebounceCts.Dispose();
            }

            var selectedDataContext = _selectedDataContext;
            var currentServerData = ContextService.CurrentServerData;
            if (selectedDataContext is null || currentServerData is null)
            {
                return;
            }

            if (!selectedDataContext.UserSkills.Any(us => us.Id == userSkill.Id))
            {
                return;
            }

            int targetLevel;
            int persistedLevel;
            lock (_skillLevelSaveDebounceLock)
            {
                targetLevel = _pendingSkillLevelBySkillId.TryGetValue(userSkill.Id, out var pendingLevel)
                    ? pendingLevel
                    : newLevel;
                persistedLevel = _lastPersistedSkillLevelBySkillId.TryGetValue(userSkill.Id, out var lastPersistedLevel)
                    ? lastPersistedLevel
                    : previousLevel;
            }

            if (targetLevel == persistedLevel)
            {
                lock (_skillLevelSaveDebounceLock)
                {
                    _pendingSkillLevelBySkillId.Remove(userSkill.Id);
                }

                return;
            }

            await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
            {
                var isIncrease = targetLevel > persistedLevel;
                userSkill.Level = targetLevel;
                UserSkillDbService.UpdateLevel(context, userSkill);

                if (selectedDataContext.UserSettings.First().OnlyLevelAccessibleRecipes)
                {
                    UserServerDataService.UserSkillLevelChange(context, selectedDataContext, currentServerData, userSkill, isIncrease);
                }

                if (!isIncrease)
                {
                    foreach (var talent in userSkill.Skill!.Talents.Where(t => t.GetCurrentUserTalent(selectedDataContext) is not null && targetLevel < t.Level))
                    {
                        UserServerDataService.RemoveUserTalent(context, talent.GetCurrentUserTalent(selectedDataContext)!);
                    }
                }

                return Task.CompletedTask;
            });

            lock (_skillLevelSaveDebounceLock)
            {
                _lastPersistedSkillLevelBySkillId[userSkill.Id] = targetLevel;
                _pendingSkillLevelBySkillId.Remove(userSkill.Id);
            }

            await RequestCalculate(CalculateTriggerOrigin.SkillChange, bypassDebounce: true);
        }
        catch (Exception ex)
        {
            _calculationError = ex;
            await InvokeAsync(StateHasChanged);
        }
    }

