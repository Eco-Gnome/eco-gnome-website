    private decimal ApplyMarginBounds(decimal margin, out bool wasAdjusted)
    {
        wasAdjusted = false;

        var min = ContextService.CurrentServer?.MarginMin;
        var max = ContextService.CurrentServer?.MarginMax;
        var adjustedValue = margin;

        if (min is not null && adjustedValue < min.Value)
        {
            adjustedValue = min.Value;
            wasAdjusted = true;
        }

        if (max is not null && adjustedValue > max.Value)
        {
            adjustedValue = max.Value;
            wasAdjusted = true;
        }

        return adjustedValue;
    }

    private async Task EnforceServerMarginPolicyIfNeeded()
    {
        if (_selectedDataContext is null || ContextService.CurrentServer is null || _selectedDataContext.UserMargins.Count == 0)
        {
            return;
        }

        var hasAnyAdjustment = false;

        foreach (var userMargin in _selectedDataContext.UserMargins)
        {
            if (ContextService.CurrentServer.IsMarginLocked)
            {
                var lockedMargin = ContextService.CurrentServer.LockedMargin ?? 0;
                if (userMargin.Margin == lockedMargin)
                {
                    continue;
                }

                userMargin.Margin = lockedMargin;
                hasAnyAdjustment = true;
            }
            else
            {
                var boundedMargin = ApplyMarginBounds(userMargin.Margin, out var wasAdjusted);
                if (!wasAdjusted)
                {
                    continue;
                }

                userMargin.Margin = boundedMargin;
                hasAnyAdjustment = true;
            }
        }

        if (!hasAnyAdjustment)
        {
            return;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            foreach (var userMargin in _selectedDataContext.UserMargins)
            {
                UserMarginDbService.UpdateAll(context, userMargin);
            }

            return Task.CompletedTask;
        });
    }

    // Add missing UserElements, UserPrices, User Skills and UserCraftingTables - in case of server data change
    private async Task MagickFix()
    {
        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            foreach (var userRecipe in _selectedDataContext!.UserRecipes)
            {
                foreach (var element in userRecipe.Recipe.Elements)
                {
                    UserServerDataService.AddUserElementIfNotExists(context, element, userRecipe.Recipe.GetCurrentUserRecipe(_selectedDataContext!)!, _selectedDataContext!);
                }

                if (userRecipe.Recipe.Skill?.GetCurrentUserSkill(_selectedDataContext!) is null)
                {
                    UserServerDataService.AddUserSkill(context, _selectedDataContext!, ContextService.CurrentServerData!, userRecipe.Recipe.Skill, _selectedDataContext!.UserSettings.First().OnlyLevelAccessibleRecipes);
                }

                if (userRecipe.Recipe.CraftingTable.GetCurrentUserCraftingTable(_selectedDataContext!) is null)
                {
                    UserServerDataService.AddUserCraftingTable(context, _selectedDataContext!, ContextService.CurrentServerData!, userRecipe.Recipe.CraftingTable);
                }
            }

            return Task.CompletedTask;
        });

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void OnContextChanged()
    {
        _ = RetrieveData();
    }

    public void Dispose()
    {
        _dataContextNameCts?.Cancel();
        _dataContextNameCts?.Dispose();
        _calculateDebounceCts?.Cancel();
        _calculateDebounceCts?.Dispose();
        lock (_skillLevelSaveDebounceLock)
        {
            foreach (var cts in _skillLevelSaveDebounceBySkillId.Values)
            {
                cts.Cancel();
                cts.Dispose();
            }

            _skillLevelSaveDebounceBySkillId.Clear();
            _pendingSkillLevelBySkillId.Clear();
            _lastPersistedSkillLevelBySkillId.Clear();
        }

        try
        {
            _ = JsRuntime.InvokeVoidAsync("ecoPriceCalculatorGroupLimiter.dispose", ItemsToSellTableDomId);
        }
        catch
        {
            // The JS runtime can be unavailable during teardown.
        }

        ContextService.OnContextChanged -= OnContextChanged;
    }

    private Task<IEnumerable<Skill>> SearchSkills(string value, CancellationToken token)
    {
        IEnumerable<Skill> result;

        if (string.IsNullOrEmpty(value))
        {
            result = UserServerDataService.GetAvailableSkills(_selectedDataContext!, ContextService.CurrentServerData!);
        }
        else
        {
            result = UserServerDataService.GetAvailableSkills(_selectedDataContext!, ContextService.CurrentServerData!)
                .Where(s => LocalizationService.GetTranslation(s).Contains(value, StringComparison.InvariantCultureIgnoreCase))
                .ToList();
        }

        result = result.Where(s => s.Profession is not null).OrderBy(s => s.Profession);

        return Task.FromResult(result);
    }

    private void RemoveTalentGroup(EcoCraftDbContext context, List<Talent> talents, DataContext dataContext)
    {
        foreach (var talent in talents)
        {
            var currentUserTalent = talent.GetCurrentUserTalent(dataContext);
            if (currentUserTalent is not null)
            {
                UserServerDataService.RemoveUserTalent(context, currentUserTalent);
            }
        }
    }

    private async Task ToggleBinaryTalent(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var isRemove = talents.All(t => t.GetCurrentUserTalent(_selectedDataContext) is not null);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            if (isRemove)
            {
                RemoveTalentGroup(context, talents, _selectedDataContext);
            }
            else
            {
                var firstTalent = talents.First();
                var selectedTalentsWithSameLevel = _selectedDataContext.UserTalents
                    .Where(ut => ut.Talent.Skill == firstTalent.Skill && ut.Talent.Level == firstTalent.Level && !talents.Contains(ut.Talent))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedDataContext);
                }

                foreach (var talent in talents)
                {
                    if (talent.GetCurrentUserTalent(_selectedDataContext) is null)
                    {
                        UserServerDataService.AddUserTalent(context, talent, _selectedDataContext);
                    }
                }
            }

            return Task.CompletedTask;
        });

        await RequestCalculate(CalculateTriggerOrigin.SkillChange);
    }

    private async Task IncreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedDataContext);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            if (existingUserTalent is null)
            {
                var selectedTalentsWithSameLevel = _selectedDataContext.UserTalents
                    .Where(ut => ut.Talent.Skill == firstTalent.Skill && ut.Talent.Level == firstTalent.Level && !talents.Contains(ut.Talent))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedDataContext);
                }

                foreach (var talent in talents)
                {
                    UserServerDataService.AddUserTalent(context, talent, _selectedDataContext);
                }
            }
            else if (existingUserTalent.Level < firstTalent.MaxLevel)
            {
                foreach (var talent in talents)
                {
                    var userTalent = talent.GetCurrentUserTalent(_selectedDataContext);
                    if (userTalent is not null)
                    {
                        userTalent.Level = Math.Min(userTalent.Level + 1, talent.MaxLevel);
                        UserTalentDbService.UpdateLevel(context, userTalent);
                    }
                }
            }

            return Task.CompletedTask;
        });

        await RequestCalculate(CalculateTriggerOrigin.SkillChange);
    }

    private async Task DecreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedDataContext);

        if (existingUserTalent is null)
        {
            return;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            foreach (var talent in talents)
            {
                var userTalent = talent.GetCurrentUserTalent(_selectedDataContext);
                if (userTalent is null)
                {
                    continue;
                }

                if (userTalent.Level <= 1)
                {
                    UserServerDataService.RemoveUserTalent(context, userTalent);
                }
                else
                {
                    userTalent.Level--;
                    UserTalentDbService.UpdateLevel(context, userTalent);
                }
            }

            return Task.CompletedTask;
        });

        await RequestCalculate(CalculateTriggerOrigin.SkillChange);
    }

