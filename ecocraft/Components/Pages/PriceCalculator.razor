    private async Task DeleteDataContext(DataContext dataContext)
    {
        if (dataContext.IsDefault)
            return;

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", LocalizationService.GetTranslation("DataContext.DeletionConfirmation", dataContext.Name));
        if (!confirmed) return;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            DataContextDbService.Destroy(context, dataContext);
            return Task.CompletedTask;
        });

        ContextService.CurrentUserServer!.DataContexts.Remove(dataContext);

        if (_selectedDataContext?.Id == dataContext.Id)
        {
            await RetrieveData(ContextService.CurrentUserServer!.DataContexts.First(d => d.IsDefault));
        }
    }

