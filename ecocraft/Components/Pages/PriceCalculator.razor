    private async Task UpdateDataContextValues(string name)
    {
        _selectedDataContext!.Name = name;
        ContextService.CurrentUserServer!.DataContexts.First(d => d.Id == _selectedDataContext.Id).Name = name;

        _dataContextNameCts?.Cancel();
        _dataContextNameCts = new CancellationTokenSource();
        var token = _dataContextNameCts.Token;

        try
        {
            await Task.Delay(300, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            DataContextDbService.UpdateName(context, _selectedDataContext);
            return Task.CompletedTask;
        });
    }

