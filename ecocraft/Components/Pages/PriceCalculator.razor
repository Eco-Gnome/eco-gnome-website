    private async Task ToggleBinaryTalent(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var isRemove = talents.All(t => t.GetCurrentUserTalent(_selectedDataContext) is not null);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            if (isRemove)
            {
                RemoveTalentGroup(context, talents, _selectedDataContext);
            }
            else
            {
                var firstTalent = talents.First();
                var selectedTalentsWithSameLevel = _selectedDataContext.UserTalents
                    .Where(ut => ut.Talent.Skill == firstTalent.Skill && ut.Talent.Level == firstTalent.Level && !talents.Contains(ut.Talent))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedDataContext);
                }

                foreach (var talent in talents)
                {
                    if (talent.GetCurrentUserTalent(_selectedDataContext) is null)
                    {
                        UserServerDataService.AddUserTalent(context, talent, _selectedDataContext);
                    }
                }
            }

            return Task.CompletedTask;
        });

        await Calculate();
    }

    private async Task IncreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedDataContext);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            if (existingUserTalent is null)
            {
                var selectedTalentsWithSameLevel = _selectedDataContext.UserTalents
                    .Where(ut => ut.Talent.Skill == firstTalent.Skill && ut.Talent.Level == firstTalent.Level && !talents.Contains(ut.Talent))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedDataContext);
                }

                foreach (var talent in talents)
                {
                    UserServerDataService.AddUserTalent(context, talent, _selectedDataContext);
                }
            }
            else if (existingUserTalent.Level < firstTalent.MaxLevel)
            {
                foreach (var talent in talents)
                {
                    var userTalent = talent.GetCurrentUserTalent(_selectedDataContext);
                    if (userTalent is not null)
                    {
                        userTalent.Level = Math.Min(userTalent.Level + 1, talent.MaxLevel);
                        UserTalentDbService.UpdateLevel(context, userTalent);
                    }
                }
            }

            return Task.CompletedTask;
        });

        await Calculate();
    }

    private async Task DecreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedDataContext is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedDataContext);

        if (existingUserTalent is null)
        {
            return;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            foreach (var talent in talents)
            {
                var userTalent = talent.GetCurrentUserTalent(_selectedDataContext);
                if (userTalent is null)
                {
                    continue;
                }

                if (userTalent.Level <= 1)
                {
                    UserServerDataService.RemoveUserTalent(context, userTalent);
                }
                else
                {
                    userTalent.Level--;
                    UserTalentDbService.UpdateLevel(context, userTalent);
                }
            }

            return Task.CompletedTask;
        });

        await Calculate();
    }

