@page "/videos-upload"
@using ecocraft.Services
@using Variant = MudBlazor.Variant
@inject ContextService ContextService
@inject ISnackbar Snackbar
@inject VideoUploadService VideoUploadService
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation

<MudPaper Class="pa-6 d-flex flex-column gap-4" Elevation="2">
    <MudText Typo="Typo.h6">Upload video (.mp4, max 20 Mo)</MudText>

    <MudStack Row>
        <MudStack>
            <MudFileUpload T="IBrowserFile"
                           Disabled="_isUploadingMp4"
                           FilesChanged="UploadMp4"
                           Accept="video/mp4">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile">
                        <MudText>Upload MP4</MudText>
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
            @if (_errorMp4 is not null)
            {
                <MudAlert Severity="Severity.Error">@_errorMp4</MudAlert>
            }
        </MudStack>
        <MudStack>
            <MudFileUpload T="IBrowserFile"
                           Disabled="_isUploadingMp3"
                           FilesChanged="UploadMp3"
                           Accept="video/mp3">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile">
                        <MudText>Upload MP3</MudText>
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
            @if (_errorMp3 is not null)
            {
                <MudAlert Severity="Severity.Error">@_errorMp3</MudAlert>
            }
        </MudStack>
    </MudStack>

    <MudPaper>
        <MudStack>
            @foreach (var file in _files)
            {
                <MudCard>
                    <MudStack Row>
                        <MudLink Href="@($"/videos/{ContextService.CurrentServer!.Id}/{file}")">
                            <MudText>@file</MudText>
                        </MudLink>
                        <MudIconButton Size="Size.Small" Icon="@MDIIcons.Filled.DeleteForever" Color="Color.Error" OnClick="@(() => DeleteFile(file))"></MudIconButton>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    </MudPaper>
</MudPaper>

@code {
    private string? _errorMp4;
    private string? _errorMp3;
    private bool _isUploadingMp4;
    private bool _isUploadingMp3;
    private List<string> _files = [];

    protected override void OnInitialized()
    {
        if (ContextService.CurrentUser == null || ContextService.CurrentUserServer == null || !ContextService.CurrentServer!.HasVideoUploader)
        {
            Navigation.NavigateTo("/");
        }

        ContextService.OnContextChanged += OnContextChanged;
    }

    private void OnContextChanged()
    {
        // Make sure you don't have access to this page if your server has not video uploader
        if (ContextService.CurrentUser == null || ContextService.CurrentUserServer == null || !ContextService.CurrentServer!.HasVideoUploader)
        {
            Navigation.NavigateTo("/");
            return;
        }

        RefreshFiles();
    }

    protected override Task OnInitializedAsync()
    {
        RefreshFiles();
        return Task.CompletedTask;
    }

    private void RefreshFiles()
    {
        _files = VideoUploadService.GetFiles(ContextService.CurrentServer!);
    }

    private async Task DeleteFile(string file)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete file {file} ?");
        if (!confirmed) return;

        VideoUploadService.DeleteFile(ContextService.CurrentServer!, file);
        RefreshFiles();
        StateHasChanged();
    }

    private async Task UploadMp4(IBrowserFile? file)
    {
        if (file is null)
            return;

        _isUploadingMp4 = true;
        _errorMp4 = null;

        try
        {
            // On ouvre le stream du browserfile
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);

            var url = await VideoUploadService.SaveFileAsync(
                ContextService.CurrentServer!,
                stream,
                file.Name,
                file.ContentType,
                file.Size
            );

            RefreshFiles();

            Snackbar.Add($"Upload OK ✅ → {url}", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorMp4 = ex.Message;
            Snackbar.Add("Upload error", Severity.Error);
        }
        finally
        {
            _isUploadingMp4 = false;
        }

        StateHasChanged();
    }

    private async Task UploadMp3(IBrowserFile? file)
    {
        if (file is null)
            return;

        _isUploadingMp3 = true;
        _errorMp3 = null;

        try
        {
            // On ouvre le stream du browserfile
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);

            await VideoUploadService.Mp3StreamToMp4Async(
                ContextService.CurrentServer!,
                stream,
                file.Name,
                file.ContentType,
                file.Size
            );

            RefreshFiles();

            Snackbar.Add("Upload ok", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorMp3 = ex.Message;
            Snackbar.Add("Upload error", Severity.Error);
        }
        finally
        {
            _isUploadingMp3 = false;
        }

        StateHasChanged();
    }
}

