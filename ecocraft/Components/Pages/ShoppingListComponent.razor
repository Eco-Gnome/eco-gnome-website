    private void Rebuild()
    {
        RebuildTree();
        StateHasChanged();
    }

    private void RemoveTalentGroup(EcoCraftDbContext context, List<Talent> talents, DataContext dataContext)
    {
        foreach (var talent in talents)
        {
            var currentUserTalent = talent.GetCurrentUserTalent(dataContext);
            if (currentUserTalent is not null)
            {
                UserServerDataService.RemoveUserTalent(context, currentUserTalent);
            }
        }
    }

    private async Task ToggleBinaryTalent(List<Talent> talents)
    {
        if (_selectedShoppingList is null || talents.Count == 0)
        {
            return;
        }

        var isRemove = talents.All(t => t.GetCurrentUserTalent(_selectedShoppingList) is not null);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            if (isRemove)
            {
                RemoveTalentGroup(context, talents, _selectedShoppingList);
            }
            else
            {
                var firstTalent = talents.First();
                var talentIds = talents.Select(t => t.Id).ToHashSet();
                var selectedTalentsWithSameLevel = _selectedShoppingList.UserTalents
                    .Where(ut => ut.Talent.SkillId == firstTalent.SkillId && ut.Talent.Level == firstTalent.Level && !talentIds.Contains(ut.TalentId))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedShoppingList);
                }

                foreach (var talent in talents)
                {
                    if (talent.GetCurrentUserTalent(_selectedShoppingList) is null)
                    {
                        UserServerDataService.AddUserTalent(context, talent, _selectedShoppingList);
                    }
                }
            }

            ShoppingListDataService.SynchronizeRecipeTree(context, _selectedShoppingList);
            await ApplyAutoChosenRecipesForMissingIngredients(context, _selectedShoppingList.UserRecipes);
        });

        Rebuild();
    }

    private async Task IncreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedShoppingList is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedShoppingList);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            if (existingUserTalent is null)
            {
                var talentIds = talents.Select(t => t.Id).ToHashSet();
                var selectedTalentsWithSameLevel = _selectedShoppingList.UserTalents
                    .Where(ut => ut.Talent.SkillId == firstTalent.SkillId && ut.Talent.Level == firstTalent.Level && !talentIds.Contains(ut.TalentId))
                    .Select(ut => ut.Talent)
                    .ToList();

                if (selectedTalentsWithSameLevel.Count > 0)
                {
                    RemoveTalentGroup(context, selectedTalentsWithSameLevel, _selectedShoppingList);
                }

                foreach (var talent in talents)
                {
                    UserServerDataService.AddUserTalent(context, talent, _selectedShoppingList);
                }
            }
            else if (existingUserTalent.Level < firstTalent.MaxLevel)
            {
                foreach (var talent in talents)
                {
                    var userTalent = talent.GetCurrentUserTalent(_selectedShoppingList);
                    if (userTalent is not null)
                    {
                        userTalent.Level = Math.Min(userTalent.Level + 1, talent.MaxLevel);
                        UserTalentDbService.UpdateLevel(context, userTalent);
                    }
                }
            }

            ShoppingListDataService.SynchronizeRecipeTree(context, _selectedShoppingList);
            await ApplyAutoChosenRecipesForMissingIngredients(context, _selectedShoppingList.UserRecipes);
        });

        Rebuild();
    }

    private async Task DecreaseTalentLevel(List<Talent> talents)
    {
        if (_selectedShoppingList is null || talents.Count == 0)
        {
            return;
        }

        var firstTalent = talents.First();
        var existingUserTalent = firstTalent.GetCurrentUserTalent(_selectedShoppingList);

        if (existingUserTalent is null)
        {
            return;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            foreach (var talent in talents)
            {
                var userTalent = talent.GetCurrentUserTalent(_selectedShoppingList);
                if (userTalent is null)
                {
                    continue;
                }

                if (userTalent.Level <= 1)
                {
                    UserServerDataService.RemoveUserTalent(context, userTalent);
                }
                else
                {
                    userTalent.Level--;
                    UserTalentDbService.UpdateLevel(context, userTalent);
                }
            }

            ShoppingListDataService.SynchronizeRecipeTree(context, _selectedShoppingList);
            await ApplyAutoChosenRecipesForMissingIngredients(context, _selectedShoppingList.UserRecipes);
        });

        Rebuild();
    }

    public async Task OnLevelChanged(UserSkill userSkill, int level)
    {
        if (_selectedShoppingList is null || userSkill.Level == level)
        {
            return;
        }

        var isIncrease = level > userSkill.Level;
        userSkill.Level = level;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            UserSkillDbService.UpdateLevel(context, userSkill);

            if (!isIncrease)
            {
                foreach (var talent in userSkill.Skill!.Talents.Where(t => t.GetCurrentUserTalent(_selectedShoppingList) is not null && level < t.Level))
                {
                    UserServerDataService.RemoveUserTalent(context, talent.GetCurrentUserTalent(_selectedShoppingList)!);
                }
            }

            ShoppingListDataService.SynchronizeRecipeTree(context, _selectedShoppingList);
            await ApplyAutoChosenRecipesForMissingIngredients(context, _selectedShoppingList.UserRecipes);
        });

        Rebuild();
    }

    private async Task IncreasePluginModule(UserCraftingTable shoppingListCraftingTable, List<PluginModule> pluginModules)
    {
        var currentIndex = pluginModules.FindIndex(pm => pm.Id == shoppingListCraftingTable.PluginModuleId);

        if (currentIndex == pluginModules.Count - 1)
        {
            return;
        }

        shoppingListCraftingTable.PluginModule = pluginModules[currentIndex + 1];
        shoppingListCraftingTable.PluginModuleId = shoppingListCraftingTable.PluginModule.Id;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            await PersistCraftingTableAndSynchronize(context, shoppingListCraftingTable);
        });

        Rebuild();
    }

    private async Task DecreasePluginModule(UserCraftingTable shoppingListCraftingTable, List<PluginModule> pluginModules)
    {
        var currentIndex = pluginModules.FindIndex(pm => pm.Id == shoppingListCraftingTable.PluginModuleId);

        switch (currentIndex)
        {
            case -1:
                return;
            case 0:
                shoppingListCraftingTable.PluginModule = null;
                shoppingListCraftingTable.PluginModuleId = null;
                break;
            default:
                shoppingListCraftingTable.PluginModule = pluginModules[currentIndex - 1];
                shoppingListCraftingTable.PluginModuleId = shoppingListCraftingTable.PluginModule.Id;
                break;
        }

        shoppingListCraftingTable.SkilledPluginModules.Clear();

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            await PersistCraftingTableAndSynchronize(context, shoppingListCraftingTable);
        });

        Rebuild();
    }

    private async Task ToggleSkilledPluginModule(UserCraftingTable shoppingListCraftingTable, PluginModule pluginModule)
    {
        var existingPluginModule = shoppingListCraftingTable.SkilledPluginModules.FirstOrDefault(pm => pm.Id == pluginModule.Id);

        if (existingPluginModule is not null)
        {
            shoppingListCraftingTable.SkilledPluginModules.Remove(existingPluginModule);
        }
        else
        {
            shoppingListCraftingTable.SkilledPluginModules.Add(pluginModule);
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            await PersistCraftingTableAndSynchronize(context, shoppingListCraftingTable);
        });

        Rebuild();
    }

    private Task<IEnumerable<Recipe>> SearchRecipes(string value, CancellationToken token)
    {
        if (ContextService.CurrentServerData is null)
        {
            return Task.FromResult(Enumerable.Empty<Recipe>());
        }

        IEnumerable<Recipe> result;

        if (string.IsNullOrEmpty(value))
        {
            result = ContextService.CurrentServerData.Recipes;
        }
        else
        {
            result = ContextService.CurrentServerData.Recipes
                .Where(r => LocalizationService.GetTranslation(r).Contains(value, StringComparison.InvariantCultureIgnoreCase))
                .ToList();
        }

        var selectedRecipeIds = _selectedShoppingList!.UserRecipes
            .Where(slr => slr.ParentUserRecipe is not null)
            .Select(slr => slr.RecipeId)
            .ToHashSet();
        result = result.Where(r => !selectedRecipeIds.Contains(r.Id)).OrderBy(r => r.Skill?.Name ?? "zzz").ThenBy(r => r.Name);

        return Task.FromResult(result);
    }


    private async Task AddShoppingListRecipe(Recipe? recipe)
    {
        if (recipe is null) return;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
        {
            var createdRecipe = await ShoppingListDataService.AddUserRecipe(context, _selectedShoppingList!, recipe, sourceDataContext: _referenceDataContext);
            await ApplyAutoChosenRecipesForMissingIngredients(context, new[] { createdRecipe });
        });

        _emptyRecipe = null;

        Rebuild();
        await RefreshRecipeAutocompleteAsync();
    }

    private async Task RemoveAllUserData()
    {
        var currentServer = ContextService.CurrentServer!;
        await ContextService.LeaveServer(ContextService.CurrentUserServer!);

        if (ContextService.CurrentUser!.UserServers.Any())
        {
            await ContextService.ChangeServer(currentServer);
        }

        Navigation.NavigateTo("/shopping-list", forceLoad: true);
    }

    private async Task PersistCraftingTableAndSynchronize(EcoCraftDbContext context, UserCraftingTable shoppingListCraftingTable)
    {
        await UserCraftingTableDbService.UpdateAllAsync(context, shoppingListCraftingTable);
        ShoppingListDataService.SynchronizeRecipeTree(context, _selectedShoppingList!);
        await ApplyAutoChosenRecipesForMissingIngredients(context, _selectedShoppingList!.UserRecipes);
    }

