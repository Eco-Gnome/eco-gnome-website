    private EconomyPlayerContextSummary? GetSelectedTargetContextSummary()
    {
        if (_drilldown is null)
        {
            return null;
        }

        var selectedTargetContextId = _selectedTargetDataContextId ?? _drilldown.SelectedTargetDataContextId;
        return ResolveContextSummary(_drilldown.TargetContextSummaries, selectedTargetContextId);
    }

    private EconomyPlayerContextSummary? GetSelectedMyContextSummary()
    {
        if (_drilldown is null)
        {
            return null;
        }

        var selectedMyContextId = _selectedMyDataContextId ?? _drilldown.SelectedMyDataContextId;
        return ResolveContextSummary(_drilldown.MyContextSummaries, selectedMyContextId);
    }

    private static EconomyPlayerContextSummary? ResolveContextSummary(
        List<EconomyPlayerContextSummary> summaries,
        Guid? selectedContextId)
    {
        if (selectedContextId is null)
        {
            return null;
        }

        return summaries.FirstOrDefault(summary => summary.DataContextId == selectedContextId.Value);
    }

    private async Task ResetDrilldownFiltersAsync()
    {
        _comparisonBy = EconomyComparisonEntity.Item;
        _comparisonOnlyDifferences = false;
        _comparisonOnlyCommon = false;
        _comparisonSearch = string.Empty;
        await LoadDrilldownAsync();
    }

    private static string FormatDecimal(decimal? value)
    {
        return value is null
            ? "-"
            : Math.Round(value.Value, 2, MidpointRounding.AwayFromZero).ToString("0.##", CultureInfo.CurrentUICulture);
    }

    private static string FormatSignedDecimal(decimal? value)
    {
        if (value is null)
        {
            return "-";
        }

        var rounded = Math.Round(value.Value, 2, MidpointRounding.AwayFromZero);
        return rounded.ToString("+0.##;-0.##;0", CultureInfo.CurrentUICulture);
    }

    private static string FormatSignedPercent(decimal? value)
    {
        if (value is null)
        {
            return "-";
        }

        var rounded = Math.Round(value.Value, 2, MidpointRounding.AwayFromZero);
        return rounded.ToString("+0.##;-0.##;0", CultureInfo.CurrentUICulture) + " %";
    }

    private string FormatSpread(EconomyGlobalRow row)
    {
        if (!_showSpreadAsPercent)
        {
            return FormatDecimal(row.Spread);
        }

        var spreadPercent = GetSpreadPercentValue(row);
        if (spreadPercent is null)
        {
            return "-";
        }

        var rounded = Math.Round(spreadPercent.Value, 2, MidpointRounding.AwayFromZero);
        return rounded.ToString("0.##", CultureInfo.CurrentUICulture) + " %";
    }

    private string FormatBooleanSetting(bool? value)
    {
        if (value is null)
        {
            return "-";
        }

        return LocalizationService.GetTranslation(value.Value
            ? "EconomyViewer.Drilldown.Values.Enabled"
            : "EconomyViewer.Drilldown.Values.Disabled");
    }

    private string FormatMarginTypeSetting(MarginType? marginType)
    {
        if (marginType is null)
        {
            return "-";
        }

        return LocalizationService.GetTranslation(marginType.Value switch
        {
            MarginType.MarkUp => "PriceCalculator.MarginType.MarkUp",
            MarginType.GrossMargin => "PriceCalculator.MarginType.GrossMargin",
            _ => marginType.Value.ToString()
        });
    }

    private static string FormatCalorieCostPer1000Setting(decimal? calorieCost)
    {
        if (calorieCost is null)
        {
            return "-";
        }

        return $"{FormatDecimal(calorieCost)} / 1000 cal";
    }

