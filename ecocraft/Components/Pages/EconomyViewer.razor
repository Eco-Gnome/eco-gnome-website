                                                            </MudStack>
                                                        </MudTd>
                                                        <MudTd>@FormatDecimal(context.CraftMinuteFee)</MudTd>
                                                    </RowTemplate>
                                                    <NoRecordsContent>
                                                        <MudText Class="pa-2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoCraftingTableData")</MudText>
                                                    </NoRecordsContent>
                                                </MudTable>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.PriceOptionsComparison")</MudText>
                                <MudTable Items="GetPriceOptionComparisonRows()" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Option")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.TargetValue")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.MyValue")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@LocalizationService.GetTranslation(context.OptionTranslationKey)</MudTd>
                                    <MudTd>@context.TargetValue</MudTd>
                                    <MudTd>@context.MyValue</MudTd>
                                </RowTemplate>
                                </MudTable>

                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.ComparisonTable")</MudText>
                                <MudTable Items="_drilldown.ComparisonRows" Filter="new Func<EconomyPlayerComparisonRow, bool>(FilterComparisonRow)" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>
                                        <MudStack Row AlignItems="AlignItems.Center">
                                            <MudTableSortLabel InitialDirection="SortDirection.Ascending"
                                                               SortBy="new Func<EconomyPlayerComparisonRow, object>(row => GetComparisonRowLabel(row))">
                                                @LocalizationService.GetTranslation("EconomyViewer.Columns.Entity")
                                            </MudTableSortLabel>
                                            <MudTextField T="string"
                                                          @bind-Value="_comparisonSearch"
                                                          Immediate
                                                          Placeholder="@LocalizationService.GetTranslation("Search")"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                                          IconSize="Size.Medium"
                                                          Class="mt-0" />
                                        </MudStack>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.TargetValue ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.TargetValue")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.MyValue ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.MyValue")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.DeltaAbs ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.DeltaAbs")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.DeltaPct ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.DeltaPct")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Status")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <EcoIcon Item="@GetComparisonRowIcon(context)"
                                                     FallbackIcon="@GetComparisonRowFallbackIcon(context)"
                                                     Size="24"/>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@GetComparisonRowLabel(context)</MudText>
                                                @if (!string.IsNullOrWhiteSpace(GetComparisonRowSubLabel(context)))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetComparisonRowSubLabel(context)</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd>@FormatDecimal(context.TargetValue)</MudTd>
                                    <MudTd>@FormatDecimal(context.MyValue)</MudTd>
                                    <MudTd>@FormatSignedDecimal(context.DeltaAbs)</MudTd>
                                    <MudTd>@FormatSignedPercent(context.DeltaPct)</MudTd>
                                    <MudTd>
                                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Variant="Variant.Outlined" Size="Size.Small">
                                            @LocalizationService.GetTranslation($"EconomyViewer.Status.{context.Status}")
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Class="pa-4">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoComparisonData")</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 200 }"/>
                                </PagerContent>
                                </MudTable>
                            </MudStack>
                        }
                            </MudStack>
                        </MudPaper>
                    </div>
                </div>
            }

            @if (_isHelpModalOpen)
            {
                <div class="economy-help-overlay" @onclick="CloseHelpModal">
                    <div class="economy-help-modal-wrapper" @onclick:stopPropagation="true">
                        <MudPaper Class="economy-help-modal pa-4" Elevation="12">
                            <MudStack Spacing="2">
                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">@LocalizationService.GetTranslation("EconomyViewer.Help.Title")</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Color="Color.Default"
                                                   OnClick="CloseHelpModal"/>
                                </MudStack>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line1")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line2")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line3")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line4")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line5")</MudText>
                            </MudStack>
                        </MudPaper>
                    </div>
                </div>
            }
    }
</MudContainer>

@code {
    private bool _isLoadingPage = true;
    private bool _isLoadingGlobal;
    private bool _isLoadingDrilldown;
    private bool _isDrilldownOpen;
    private bool _isHelpModalOpen;

    private EconomyGroupBy _groupBy = EconomyGroupBy.Item;
    private string _searchText = string.Empty;
    private bool _showIncompleteRows;
    private bool _showSpreadAsPercent;
    private Guid? _filterSkillId;
    private Guid? _globalFilterUserServerId;

    private Guid? _selectedTargetUserServerId;
    private Guid? _selectedTargetDataContextId;
    private Guid? _selectedMyDataContextId;
    private EconomyComparisonEntity _comparisonBy = EconomyComparisonEntity.Item;
    private bool _comparisonOnlyDifferences;
    private bool _comparisonOnlyCommon;
    private string _comparisonSearch = string.Empty;

    private EconomyGlobalResult _globalResult = new();
    private EconomyPlayerDetailResult? _drilldown;

    private List<ItemOrTag> _availableItems = [];
    private List<Recipe> _availableRecipes = [];
    private List<Skill> _availableSkills = [];
    private List<CraftingTable> _availableCraftingTables = [];
    private List<PluginModule> _availablePluginModules = [];
    private List<UserServer> _availablePlayers = [];
    private Dictionary<Guid, ItemOrTag> _itemsById = [];
    private Dictionary<Guid, Recipe> _recipesById = [];
    private Dictionary<Guid, Skill> _skillsById = [];
    private Dictionary<Guid, CraftingTable> _craftingTablesById = [];
    private Dictionary<Guid, PluginModule> _pluginModulesById = [];
    private Dictionary<Guid, ItemOrTag> _recipeProductItemsByRecipeId = [];
    private const string ShowIncompleteRowsStorageKey = "EconomyViewer.ShowIncompleteRows";
    private const string ShowSpreadAsPercentStorageKey = "EconomyViewer.ShowSpreadAsPercent";

    protected override void OnInitialized()
    {
        ContextService.OnContextChanged += OnContextChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeAndLoadAsync();
    }

    private async Task InitializeAndLoadAsync()
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null)
        {
            _isLoadingPage = false;
            StateHasChanged();
            return;
        }

        try
        {
            _isLoadingPage = true;
            _showIncompleteRows = await LocalStorageService.GetItem(ShowIncompleteRowsStorageKey) == "True";
            _showSpreadAsPercent = await LocalStorageService.GetItem(ShowSpreadAsPercentStorageKey) == "True";
            await EnsureServerDataLoadedAsync();
            _selectedTargetUserServerId ??= ContextService.CurrentUserServer.Id;
            await LoadGlobalAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadGlobal")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingPage = false;
            StateHasChanged();
        }
    }

    private async Task EnsureServerDataLoadedAsync()
    {
        if (ContextService.CurrentServer is null)
        {
            return;
        }

        if (ContextService.CurrentServerData is null || ContextService.CurrentServerData.Id != ContextService.CurrentServer.Id)
        {
            ContextService.CurrentServerData = await ServerDbService.GetServerWithData(ContextService.CurrentServer.Id);
        }

        _availableItems = ContextService.CurrentServerData.ItemOrTags
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availableRecipes = ContextService.CurrentServerData.Recipes
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        var allSkills = ContextService.CurrentServerData.Skills
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availableSkills = allSkills
            .Where(s => s.Profession is not null)
            .ToList();

        _availableCraftingTables = ContextService.CurrentServerData.CraftingTables
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availablePluginModules = ContextService.CurrentServerData.PluginModules
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availablePlayers = ContextService.CurrentServer.UserServers
            .OrderBy(us => us.GetPseudo())
            .ToList();

        _itemsById = _availableItems.ToDictionary(i => i.Id);
        _recipesById = _availableRecipes.ToDictionary(r => r.Id);
        _skillsById = allSkills.ToDictionary(s => s.Id);
        _craftingTablesById = _availableCraftingTables.ToDictionary(ct => ct.Id);
        _pluginModulesById = _availablePluginModules.ToDictionary(pm => pm.Id);
        _recipeProductItemsByRecipeId = _availableRecipes
            .Select(recipe => new
            {
                recipe.Id,
                ProductItem = recipe.Elements.FirstOrDefault(e => e.IsProduct())?.ItemOrTag
            })
            .Where(x => x.ProductItem is not null)
            .ToDictionary(x => x.Id, x => x.ProductItem!);
    }

    private async Task LoadGlobalAsync(bool showLoadingIndicator = true)
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null)
        {
            return;
        }

        try
        {
            if (showLoadingIndicator)
            {
                _isLoadingGlobal = true;
                StateHasChanged();
            }

            var query = new EconomyGlobalQuery
            {
                ServerId = ContextService.CurrentServer.Id,
                GroupBy = _groupBy,
                SearchText = string.Empty,
                SkillId = _filterSkillId,
                UserServerId = _globalFilterUserServerId,
                SortBy = EconomyGlobalSortBy.Label,
                SortDescending = false,
                Page = 1,
                PageSize = 0
            };

            _globalResult = await EconomyViewerService.GetGlobalAsync(query, ContextService.CurrentUserServer.Id);
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(LocalizationService.GetTranslation("EconomyViewer.Errors.Unauthorized"), Severity.Error);
            _globalResult = new EconomyGlobalResult();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadGlobal")}: {ex.Message}", Severity.Error);
            _globalResult = new EconomyGlobalResult();
        }
        finally
        {
            if (showLoadingIndicator)
            {
                _isLoadingGlobal = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDrilldownAsync()
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null || _selectedTargetUserServerId is null)
        {
            return;
        }

        try
        {
            _isLoadingDrilldown = true;
            StateHasChanged();

            var query = new EconomyPlayerDetailQuery
            {
                ServerId = ContextService.CurrentServer.Id,
                RequestingUserServerId = ContextService.CurrentUserServer.Id,
                TargetUserServerId = _selectedTargetUserServerId.Value,
                TargetDataContextId = _selectedTargetDataContextId,
                MyDataContextId = _selectedMyDataContextId,
                ComparisonBy = _comparisonBy,
                SortBy = EconomyComparisonSortBy.Entity,
                SortDescending = false,
                SearchText = string.Empty,
                OnlyDifferences = false,
                Page = 1,
                PageSize = 0
            };

            _drilldown = await EconomyViewerService.GetPlayerDetailAsync(query);
            _selectedTargetDataContextId = _drilldown.SelectedTargetDataContextId;
            _selectedMyDataContextId = _drilldown.SelectedMyDataContextId;
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(LocalizationService.GetTranslation("EconomyViewer.Errors.Unauthorized"), Severity.Error);
            _drilldown = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadDrilldown")}: {ex.Message}", Severity.Error);
            _drilldown = null;
        }
        finally
        {
            _isLoadingDrilldown = false;
            StateHasChanged();
        }
    }

    private async Task OnGroupByChanged(EconomyGroupBy value)
    {
        _groupBy = value;

        await LoadGlobalAsync();
    }

    private async Task OnGlobalPlayerFilterChanged(Guid? value)
    {
        _globalFilterUserServerId = value;
        await LoadGlobalAsync();
    }

    private async Task OnGlobalSkillFilterChanged(Guid? value)
    {
        _filterSkillId = value;
        await LoadGlobalAsync();
    }

    private async Task ResetGlobalFilters()
    {
        _groupBy = EconomyGroupBy.Item;
        _searchText = string.Empty;
        _showIncompleteRows = false;
        _filterSkillId = null;
        _globalFilterUserServerId = null;
        await LocalStorageService.AddItem(ShowIncompleteRowsStorageKey, bool.FalseString);
        await LoadGlobalAsync();
    }

    private bool FilterGlobalRow(EconomyGlobalRow row)
    {
        if (!_showIncompleteRows && !IsCompleteEconomyRow(row))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var search = _searchText.Trim();

        if (GetGlobalRowLabel(row).Contains(search, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var subLabel = GetGlobalRowSubLabel(row);
        return !string.IsNullOrWhiteSpace(subLabel) && subLabel.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OnShowIncompleteRowsChanged(bool value)
    {
        _showIncompleteRows = value;
        await LocalStorageService.AddItem(ShowIncompleteRowsStorageKey, value.ToString());
    }

    private async Task ToggleSpreadDisplayMode()
    {
        _showSpreadAsPercent = !_showSpreadAsPercent;
        await LocalStorageService.AddItem(ShowSpreadAsPercentStorageKey, _showSpreadAsPercent.ToString());
    }

    private static bool IsCompleteEconomyRow(EconomyGlobalRow row)
    {
        return row.PriceMin is not null
               && row.PriceAverage is not null
               && row.PriceMax is not null
               && row.MarginMin is not null
               && row.MarginAverage is not null
               && row.MarginMax is not null
               && row.Spread is not null;
    }

    private bool FilterComparisonRow(EconomyPlayerComparisonRow row)
    {
        if (_comparisonOnlyDifferences && !row.IsDifferent)
        {
            return false;
        }

        if (_comparisonOnlyCommon && !IsCommonComparisonRow(row))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_comparisonSearch))
        {
            return true;
        }

        var search = _comparisonSearch.Trim();

        if (GetComparisonRowLabel(row).Contains(search, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var subLabel = GetComparisonRowSubLabel(row);
        return !string.IsNullOrWhiteSpace(subLabel) && subLabel.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private Task OnComparisonOnlyDifferencesChanged(bool value)
    {
        _comparisonOnlyDifferences = value;
        if (value)
        {
            _comparisonOnlyCommon = false;
        }

        return Task.CompletedTask;
    }

    private Task OnComparisonOnlyCommonChanged(bool value)
    {
        _comparisonOnlyCommon = value;
        if (value)
        {
            _comparisonOnlyDifferences = false;
        }

        return Task.CompletedTask;
    }

    private static bool IsCommonComparisonRow(EconomyPlayerComparisonRow row)
    {
        return row.TargetValue is not null && row.MyValue is not null;
    }

    private async Task OpenTargetPlayerDrilldown()
    {
        await OpenDrilldownAsync(_selectedTargetUserServerId);
    }

    private async Task OpenDrilldownAsync(Guid? targetUserServerId)
    {
        if (targetUserServerId is null)
        {
            return;
        }

        _selectedTargetUserServerId = targetUserServerId;
        _isDrilldownOpen = true;
        await LoadDrilldownAsync();
    }

    private void CloseDrilldown()
    {
        _isDrilldownOpen = false;
    }

    private void OpenHelpModal()
    {
        _isHelpModalOpen = true;
    }

    private void CloseHelpModal()
    {
        _isHelpModalOpen = false;
    }

    private async Task OnTargetPlayerChangedInDrawer(Guid? value)
    {
        _selectedTargetUserServerId = value;
        _selectedTargetDataContextId = null;
        await LoadDrilldownAsync();
    }

    private async Task OnComparisonByChanged(EconomyComparisonEntity value)
    {
        _comparisonBy = value;
        await LoadDrilldownAsync();
    }

    private async Task OnTargetContextChanged(Guid? value)
    {
        _selectedTargetDataContextId = value;
        await LoadDrilldownAsync();
    }

    private async Task OnMyContextChanged(Guid? value)
    {
        _selectedMyDataContextId = value;
        await LoadDrilldownAsync();
    }

    private IEnumerable<DrilldownContextDisplayRow> GetSelectedContextSummaries()
    {
        if (_drilldown is null)
        {
            return [];
        }

        var rows = new List<DrilldownContextDisplayRow>();

        var targetSummary = GetSelectedTargetContextSummary();
        if (targetSummary is not null)
        {
            rows.Add(new DrilldownContextDisplayRow
            {
                RoleTranslationKey = "EconomyViewer.Drilldown.TargetBadge",
                PlayerName = _drilldown.TargetPlayerName,
                RoleColor = Color.Primary,
                Summary = targetSummary
            });
        }

        var mySummary = GetSelectedMyContextSummary();
        if (mySummary is not null)
        {
            rows.Add(new DrilldownContextDisplayRow
            {
                RoleTranslationKey = "EconomyViewer.Drilldown.MyBadge",
                PlayerName = _drilldown.MyPlayerName,
                RoleColor = Color.Secondary,
                Summary = mySummary
            });
        }

        return rows;
    }

    private IEnumerable<DrilldownOptionComparisonRow> GetPriceOptionComparisonRows()
    {
        var targetSummary = GetSelectedTargetContextSummary();
        var mySummary = GetSelectedMyContextSummary();

        return
        [
            new DrilldownOptionComparisonRow
            {
                OptionTranslationKey = "PriceCalculator.ApplyMarginBetweenSkills.ApplyMarginBetweenSkills",
                TargetValue = FormatBooleanSetting(targetSummary?.ApplyMarginBetweenSkills),
                MyValue = FormatBooleanSetting(mySummary?.ApplyMarginBetweenSkills)
            },
            new DrilldownOptionComparisonRow
            {
                OptionTranslationKey = "PriceCalculator.MarginType.MarginType",
                TargetValue = FormatMarginTypeSetting(targetSummary?.MarginType),
                MyValue = FormatMarginTypeSetting(mySummary?.MarginType)
            },
            new DrilldownOptionComparisonRow
            {
                OptionTranslationKey = "PriceCalculator.CalorieCost.CalorieCost",
                TargetValue = FormatCalorieCostPer1000Setting(targetSummary?.CalorieCost),
                MyValue = FormatCalorieCostPer1000Setting(mySummary?.CalorieCost)
            }
        ];
    }

    private IEnumerable<EconomyPlayerCraftingTableSummary> GetSelectedTargetCraftingTableSummaries()
    {
        if (_drilldown is null)
        {
            return [];
        }

        var selectedTargetContextId = _selectedTargetDataContextId ?? _drilldown.SelectedTargetDataContextId;
        if (selectedTargetContextId is null)
        {
            return [];
        }

        var filteredCraftingTableIds = GetCraftingTableIdsFilteredByComparisonToggles();

        return _drilldown.TargetCraftingTableSummaries
            .Where(summary => summary.DataContextId == selectedTargetContextId.Value)
            .Where(summary => filteredCraftingTableIds.Contains(summary.CraftingTableId))
            .OrderBy(GetCraftingTableSortLabel)
            .ToList();
    }

    private IEnumerable<EconomyPlayerCraftingTableSummary> GetSelectedMyCraftingTableSummaries()
    {
        if (_drilldown is null)
        {
            return [];
        }

        var selectedMyContextId = _selectedMyDataContextId ?? _drilldown.SelectedMyDataContextId;
        if (selectedMyContextId is null)
        {
            return [];
        }

        var filteredCraftingTableIds = GetCraftingTableIdsFilteredByComparisonToggles();

        return _drilldown.MyCraftingTableSummaries
            .Where(summary => summary.DataContextId == selectedMyContextId.Value)
            .Where(summary => filteredCraftingTableIds.Contains(summary.CraftingTableId))
            .OrderBy(GetCraftingTableSortLabel)
            .ToList();
    }

    private HashSet<Guid> GetCraftingTableIdsFilteredByComparisonToggles()
    {
        if (_drilldown is null)
        {
            return [];
        }

        var selectedTargetContextId = _selectedTargetDataContextId ?? _drilldown.SelectedTargetDataContextId;
        var selectedMyContextId = _selectedMyDataContextId ?? _drilldown.SelectedMyDataContextId;

        var targetCraftingTableIds = selectedTargetContextId is null
            ? []
            : _drilldown.TargetCraftingTableSummaries
                .Where(summary => summary.DataContextId == selectedTargetContextId.Value)
                .Select(summary => summary.CraftingTableId)
                .ToHashSet();

        var myCraftingTableIds = selectedMyContextId is null
            ? []
            : _drilldown.MyCraftingTableSummaries
                .Where(summary => summary.DataContextId == selectedMyContextId.Value)
                .Select(summary => summary.CraftingTableId)
                .ToHashSet();

        if (_comparisonOnlyCommon)
        {
            targetCraftingTableIds.IntersectWith(myCraftingTableIds);
            return targetCraftingTableIds;
        }

        if (_comparisonOnlyDifferences)
        {
            targetCraftingTableIds.SymmetricExceptWith(myCraftingTableIds);
            return targetCraftingTableIds;
        }

        targetCraftingTableIds.UnionWith(myCraftingTableIds);
        return targetCraftingTableIds;
    }

    private string GetSelectedTargetContextTitle()
    {
        if (_drilldown is null)
        {
            return "-";
        }

        var summary = GetSelectedTargetContextSummary();
        return summary is null
            ? _drilldown.TargetPlayerName
            : $"{_drilldown.TargetPlayerName} - {summary.DataContextName}";
    }

    private string GetSelectedMyContextTitle()
    {
        if (_drilldown is null)
        {
            return "-";
        }

        var summary = GetSelectedMyContextSummary();
        return summary is null
            ? _drilldown.MyPlayerName
            : $"{_drilldown.MyPlayerName} - {summary.DataContextName}";
    }

    private string GetCraftingTableSortLabel(EconomyPlayerCraftingTableSummary summary)
    {
        if (_craftingTablesById.TryGetValue(summary.CraftingTableId, out var craftingTable))
        {
            return LocalizationService.GetTranslation(craftingTable);
        }

        return summary.CraftingTableName;
    }

    private string GetCraftingTableLabel(EconomyPlayerCraftingTableSummary summary)
    {
        return GetCraftingTableSortLabel(summary);
    }

    private CraftingTable? GetCraftingTable(Guid craftingTableId)
    {
        return _craftingTablesById.GetValueOrDefault(craftingTableId);
    }

    private PluginModule? GetPluginModule(Guid pluginModuleId)
    {
