    private object GetSpreadSortValue(EconomyGlobalRow row)
    {
        if (!_showSpreadAsPercent)
        {
            return row.Spread ?? decimal.MaxValue;
        }

        return GetSpreadPercentValue(row) ?? decimal.MaxValue;
    }

    private static decimal? GetSpreadPercentValue(EconomyGlobalRow row)
    {
        if (row.Spread is null || row.PriceMin is null)
        {
            return null;
        }

        if (row.Spread == 0)
        {
            return 0;
        }

        if (row.PriceMin == 0)
        {
            return null;
        }

        return row.Spread.Value / row.PriceMin.Value * 100m;
    }

    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            "Higher" => Color.Warning,
            "Lower" => Color.Success,
            "Same" => Color.Info,
            "OnlyTarget" => Color.Primary,
            "OnlyMine" => Color.Secondary,
            _ => Color.Default
        };
    }

    private IHasIconName? GetGlobalRowIcon(EconomyGlobalRow row)
    {
        if (row.ItemOrTagId is Guid itemId && _itemsById.TryGetValue(itemId, out var item))
        {
            return item;
        }

        if (row.RecipeId is Guid recipeId && _recipeProductItemsByRecipeId.TryGetValue(recipeId, out var recipeProductItem))
        {
            return recipeProductItem;
        }

        if (row.SkillId is Guid skillId && _skillsById.TryGetValue(skillId, out var skill))
        {
            return skill;
        }

        return null;
    }

