@page "/economy-viewer"
@implements IDisposable
@using System.Globalization
@using ecocraft.Extensions
@using ecocraft.Models
@using ecocraft.Services
@using ecocraft.Services.DbServices
@using ecocraft.Components.Utils
@inject ContextService ContextService
@inject ServerDbService ServerDbService
@inject EconomyViewerService EconomyViewerService
@inject LocalizationService LocalizationService
@inject LocalStorageService LocalStorageService
@inject ISnackbar Snackbar

<PageTitle>@LocalizationService.GetTranslation("EconomyViewer.PageTitle") - Eco Gnome</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-0">
    @if (_isLoadingPage)
    {
        <MudItem xs="12" Class="px-4 pt-4">
            <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudProgressCircular Size="Size.Large" Color="Color.Primary" Indeterminate="true"/>
            </MudStack>
        </MudItem>
    }
    else if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-4">
            @LocalizationService.GetTranslation("EconomyViewer.ServerContextMissing")
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="2" Class="px-4 pt-4">
                    <MudPaper Class="pa-3">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudSelect T="EconomyGroupBy"
                                           Value="_groupBy"
                                           Label="@LocalizationService.GetTranslation("EconomyViewer.Filters.GroupBy")"
                                           Variant="Variant.Outlined"
                                           ValueChanged="OnGroupByChanged">
                                    <MudSelectItem T="EconomyGroupBy" Value="EconomyGroupBy.Item">@LocalizationService.GetTranslation("EconomyViewer.Groups.Item")</MudSelectItem>
                                    <MudSelectItem T="EconomyGroupBy" Value="EconomyGroupBy.Recipe">@LocalizationService.GetTranslation("EconomyViewer.Groups.Recipe")</MudSelectItem>
                                    <MudSelectItem T="EconomyGroupBy" Value="EconomyGroupBy.Skill">@LocalizationService.GetTranslation("EconomyViewer.Groups.Skill")</MudSelectItem>
                                    <MudSelectItem T="EconomyGroupBy" Value="EconomyGroupBy.Player">@LocalizationService.GetTranslation("EconomyViewer.Groups.Player")</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="Guid?"
                                           Value="_globalFilterUserServerId"
                                           Label="@LocalizationService.GetTranslation("EconomyViewer.Filters.Player")"
                                           Variant="Variant.Outlined"
                                           ValueChanged="OnGlobalPlayerFilterChanged">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@LocalizationService.GetTranslation("EconomyViewer.Filters.AllPlayers")</MudSelectItem>
                                    @foreach (var player in _availablePlayers)
                                    {
                                        <MudSelectItem T="Guid?" Value="@player.Id">@player.GetPseudo()</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="Guid?"
                                           Value="_filterSkillId"
                                           Label="@LocalizationService.GetTranslation("EconomyViewer.Filters.Skill")"
                                           Variant="Variant.Outlined"
                                           ValueChanged="OnGlobalSkillFilterChanged">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@LocalizationService.GetTranslation("EconomyViewer.Filters.AllSkills")</MudSelectItem>
                                    @foreach (var skill in _availableSkills)
                                    {
                                        <MudSelectItem T="Guid?" Value="@skill.Id">@LocalizationService.GetTranslation(skill)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               OnClick="ResetGlobalFilters">
                                        @LocalizationService.GetTranslation("EconomyViewer.Actions.ResetFilters")
                                    </MudButton>
                                    <MudSwitch T="bool"
                                               Value="_showIncompleteRows"
                                               ValueChanged="OnShowIncompleteRowsChanged"
                                               Color="@(_showIncompleteRows ? Color.Primary : Color.Default)"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Filters.ShowIncompleteRows")"/>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <MudPaper Class="pa-3">
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.h6">@LocalizationService.GetTranslation("EconomyViewer.GlobalViewTitle")</MudText>
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small">
                                    @LocalizationService.GetTranslation("EconomyViewer.ReadOnlyChip")
                                </MudChip>
                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Text">
                                    @_globalResult.TotalCount
                                </MudChip>
                            </MudStack>
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudTooltip Text="@LocalizationService.GetTranslation("EconomyViewer.Actions.Help")">
                                    <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   OnClick="OpenHelpModal"/>
                                </MudTooltip>
                                <MudTooltip Text="@GetOpenDrilldownTooltip()">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Tertiary"
                                               Disabled="@(!CanOpenDrilldown)"
                                               OnClick="OpenDefaultDrilldown">
                                        @LocalizationService.GetTranslation("EconomyViewer.Actions.OpenDrilldown")
                                    </MudButton>
                                </MudTooltip>
                            </MudStack>
                        </MudStack>

                        @if (_isLoadingGlobal)
                        {
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-6">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
                            </MudStack>
                        }
                        else
                        {
                            <MudTable Items="_globalResult.Rows" Filter="new Func<EconomyGlobalRow, bool>(FilterGlobalRow)" Dense="true" Hover="true" Class="mt-3">
                                <HeaderContent>
                                    @if (ShouldShowGlobalExpansionColumn())
                                    {
                                        <MudTh Class="economy-global-expand-cell"></MudTh>
                                    }
                                    <MudTh>
                                        <MudStack Row AlignItems="AlignItems.Center">
                                            <MudTableSortLabel InitialDirection="SortDirection.Ascending"
                                                               SortBy="new Func<EconomyGlobalRow, object>(row => GetGlobalRowLabel(row))">
                                                @LocalizationService.GetTranslation("EconomyViewer.Columns.Entity")
                                            </MudTableSortLabel>
                                            <MudTextField T="string"
                                                          @bind-Value="_searchText"
                                                          Immediate
                                                          Placeholder="@LocalizationService.GetTranslation("Search")"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                                          IconSize="Size.Medium"
                                                          Class="mt-0" />
                                        </MudStack>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.PriceMin ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.PriceMin")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.PriceAverage ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.PriceAvg")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.PriceMax ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.PriceMax")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.MarginMin ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.MarginMin")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.MarginAverage ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.MarginAvg")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.MarginMax ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.MarginMax")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(row => row.ConfiguredPlayersCount)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Columns.ConfiguredPlayers")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <MudTableSortLabel SortBy="new Func<EconomyGlobalRow, object>(GetSpreadSortValue)">
                                                @LocalizationService.GetTranslation("EconomyViewer.Columns.Spread")
                                            </MudTableSortLabel>
                                            <MudIconButton Color="Color.Primary"
                                                           Icon="@(_showSpreadAsPercent ? MDIIcons.Outline.PercentBox : MDIIcons.Outline.Numeric1Box)"
                                                           Size="Size.Small"
                                                           OnClick="@(() => ToggleSpreadDisplayMode())"/>
                                        </MudStack>
                                    </MudTh>
                                    @if (_groupBy is EconomyGroupBy.Player)
                                    {
                                        <MudTh></MudTh>
                                    }
                                </HeaderContent>
                                <RowTemplate>
                                    @if (ShouldShowGlobalExpansionColumn())
                                    {
                                        <MudTd Class="economy-global-expand-cell">
                                            @if (CanExpandGlobalRow(context))
                                            {
                                                <MudIconButton Icon="@(IsGlobalRowExpanded(context) ? MDIIcons.Filled.ChevronDown : MDIIcons.Filled.ChevronRight)"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(() => ToggleGlobalRowExpansion(context))"/>
                                            }
                                        </MudTd>
                                    }
                                    <MudTd>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <EcoIcon Item="@GetGlobalRowIcon(context)"
                                                     FallbackIcon="@GetGlobalRowFallbackIcon(context)"
                                                     Size="24"/>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@GetGlobalRowLabel(context)</MudText>
                                                @if (!string.IsNullOrWhiteSpace(GetGlobalRowSubLabel(context)))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetGlobalRowSubLabel(context)</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd>@FormatDecimal(context.PriceMin)</MudTd>
                                    <MudTd>@FormatDecimal(context.PriceAverage)</MudTd>
                                    <MudTd>@FormatDecimal(context.PriceMax)</MudTd>
                                    <MudTd>@FormatDecimal(context.MarginMin)</MudTd>
                                    <MudTd>@FormatDecimal(context.MarginAverage)</MudTd>
                                    <MudTd>@FormatDecimal(context.MarginMax)</MudTd>
                                    <MudTd>@context.ConfiguredPlayersCount</MudTd>
                                    <MudTd>@FormatSpread(context)</MudTd>
                                    @if (_groupBy is EconomyGroupBy.Player && context.UserServerId is Guid userServerId)
                                    {
                                        <MudTd>
                                            <MudTooltip Text="@GetOpenDrilldownTooltip()">
                                                <MudIconButton Icon="@Icons.Material.Filled.PersonSearch"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               Disabled="@(!CanOpenDrilldown)"
                                                               OnClick="@(async () => await OpenDrilldownFromPlayerRowAsync(userServerId))"/>
                                            </MudTooltip>
                                        </MudTd>
                                    }
                                </RowTemplate>
                                <ChildRowContent>
                                    @if (CanExpandGlobalRow(context) && IsGlobalRowExpanded(context))
                                    {
                                        <MudTr>
                                            <MudTd colspan="@GetGlobalTableColumnCount()" Class="economy-global-player-details-cell">
                                                <MudTable Items="GetGlobalRowPlayerDetails(context)" Dense="true" Hover="true" Elevation="0" Class="economy-global-player-details-table">
                                                    <HeaderContent>
                                                        <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Groups.Player")</MudTh>
                                                        @if (_groupBy is EconomyGroupBy.Item or EconomyGroupBy.Recipe)
                                                        {
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.PriceAvg")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.MarginAvg")</MudTh>
                                                        }
                                                        @if (_groupBy is EconomyGroupBy.Item)
                                                        {
                                                            <MudTh>@LocalizationService.GetTranslation("Recipe")</MudTh>
                                                        }
                                                        @if (_groupBy is EconomyGroupBy.Skill)
                                                        {
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.PriceMin")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.PriceAvg")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.PriceMax")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.MarginMin")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.MarginAvg")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.MarginMax")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.ConfiguredContexts")</MudTh>
                                                            <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.Spread")</MudTh>
                                                        }
                                                        <MudTh></MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate Context="playerDetail">
                                                        <MudTd>
                                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small"/>
                                                                <MudText Typo="Typo.body2">@playerDetail.PlayerName</MudText>
                                                            </MudStack>
                                                        </MudTd>
                                                        @if (_groupBy is EconomyGroupBy.Item or EconomyGroupBy.Recipe)
                                                        {
                                                            <MudTd>@FormatDecimal(playerDetail.PriceAverage)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.MarginAverage)</MudTd>
                                                        }
                                                        @if (_groupBy is EconomyGroupBy.Item)
                                                        {
                                                            <MudTd>@GetPrimaryRecipeLabel(playerDetail)</MudTd>
                                                        }
                                                        @if (_groupBy is EconomyGroupBy.Skill)
                                                        {
                                                            <MudTd>@FormatDecimal(playerDetail.PriceMin)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.PriceAverage)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.PriceMax)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.MarginMin)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.MarginAverage)</MudTd>
                                                            <MudTd>@FormatDecimal(playerDetail.MarginMax)</MudTd>
                                                            <MudTd>@playerDetail.ConfiguredContextsCount</MudTd>
                                                            <MudTd>@FormatPlayerDetailSpread(playerDetail)</MudTd>
                                                        }
                                                        <MudTd>
                                                            <MudTooltip Text="@GetOpenDrilldownTooltip()">
                                                                <MudIconButton Icon="@Icons.Material.Filled.PersonSearch"
                                                                               Color="Color.Primary"
                                                                               Size="Size.Small"
                                                                               Disabled="@(!CanOpenDrilldown)"
                                                                               OnClick="@(async () => await OpenDrilldownFromPlayerRowAsync(playerDetail.UserServerId))"/>
                                                            </MudTooltip>
                                                        </MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            </MudTd>
                                        </MudTr>
                                    }
                                </ChildRowContent>
                                <NoRecordsContent>
                                    <MudText Class="pa-4">@LocalizationService.GetTranslation("EconomyViewer.NoGlobalData")</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 200 }"/>
                                </PagerContent>
                            </MudTable>
                        }
                    </MudPaper>
                </MudStack>

            @if (_isDrilldownOpen)
            {
                <div class="economy-drilldown-overlay" @onclick="CloseDrilldown">
                    <div class="economy-drilldown-modal-wrapper" @onclick:stopPropagation="true">
                        <MudPaper Class="economy-drilldown-modal pa-4" Elevation="12">
                            <MudStack Spacing="3">
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Title")</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Default"
                                           OnClick="CloseDrilldown"/>
                        </MudStack>

                        @if (_isLoadingDrilldown)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                                <MudProgressCircular Color="Color.Tertiary" Indeterminate="true"/>
                            </MudStack>
                        }
                        else if (_drilldown is null)
                        {
                            <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoData")</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.caption">
                                    @LocalizationService.GetTranslation("EconomyViewer.Drilldown.CompareHeader", _drilldown.Player1Name, _drilldown.Player2Name)
                                </MudText>

                                <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?"
                                               Value="_selectedPlayer1UserServerId"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player1")"
                                               Variant="Variant.Outlined"
                                               ValueChanged="OnPlayer1ChangedInDrawer">
                                        @foreach (var player in _availablePlayers)
                                        {
                                            <MudSelectItem T="Guid?"
                                                           Value="@player.Id"
                                                           Disabled="@(_selectedPlayer2UserServerId == player.Id)">
                                                @player.GetPseudo()
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?"
                                               Value="_selectedPlayer2UserServerId"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player2")"
                                               Variant="Variant.Outlined"
                                               ValueChanged="OnPlayer2ChangedInDrawer">
                                        @foreach (var player in _availablePlayers)
                                        {
                                            <MudSelectItem T="Guid?"
                                                           Value="@player.Id"
                                                           Disabled="@(_selectedPlayer1UserServerId == player.Id)">
                                                @player.GetPseudo()
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?"
                                               Value="_selectedPlayer1DataContextId"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player1Context")"
                                               Variant="Variant.Outlined"
                                               ValueChanged="OnPlayer1ContextChanged">
                                        @foreach (var context in _drilldown.Player1Contexts)
                                        {
                                            <MudSelectItem T="Guid?" Value="@context.Id">@context.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?"
                                               Value="_selectedPlayer2DataContextId"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player2Context")"
                                               Variant="Variant.Outlined"
                                               ValueChanged="OnPlayer2ContextChanged">
                                        @foreach (var context in _drilldown.Player2Contexts)
                                        {
                                            <MudSelectItem T="Guid?" Value="@context.Id">@context.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                        <MudSwitch T="bool"
                                                   Value="_comparisonOnlyDifferences"
                                                   ValueChanged="OnComparisonOnlyDifferencesChanged"
                                                   Color="@(_comparisonOnlyDifferences ? Color.Primary : Color.Default)"
                                                   Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.OnlyDifferences")"/>
                                        <MudSwitch T="bool"
                                                   Value="_comparisonOnlyCommon"
                                                   ValueChanged="OnComparisonOnlyCommonChanged"
                                                   Color="@(_comparisonOnlyCommon ? Color.Primary : Color.Default)"
                                                   Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.OnlyCommon")"/>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Default"
                                                   OnClick="ResetDrilldownFiltersAsync">
                                            @LocalizationService.GetTranslation("EconomyViewer.Actions.ResetFilters")
                                        </MudButton>
                                    </MudStack>
                                </MudItem>
                                </MudGrid>

                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.ContextSummaries")</MudText>
                                <MudTable Items="GetSelectedContextSummaries()" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Role")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Player")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Context")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.ConfiguredItems")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.PriceAvg")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Columns.MarginAvg")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Recipes")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Skills")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudChip T="string" Color="@context.RoleColor" Variant="Variant.Outlined" Size="Size.Small">
                                            @LocalizationService.GetTranslation(context.RoleTranslationKey)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>@context.PlayerName</MudTd>
                                    <MudTd>@context.Summary.DataContextName</MudTd>
                                    <MudTd>@context.Summary.ConfiguredItemCount</MudTd>
                                    <MudTd>@FormatDecimal(context.Summary.AveragePrice)</MudTd>
                                    <MudTd>@FormatDecimal(context.Summary.AverageMargin)</MudTd>
                                    <MudTd>@context.Summary.RecipeCount</MudTd>
                                    <MudTd>@context.Summary.SkillCount</MudTd>
                                </RowTemplate>
                                </MudTable>

                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.CraftingTablesComparison")</MudText>
                                <MudGrid>
                                    <MudItem xs="12" md="6" Class="d-flex">
                                        <MudPaper Class="pa-3 flex-grow-1">
                                            <MudStack Spacing="1">
                                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                                        @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player1Badge")
                                                    </MudChip>
                                                    <MudText Typo="Typo.body2">@GetSelectedPlayer1ContextTitle()</MudText>
                                                </MudStack>
                                                <MudTable Items="GetSelectedPlayer1CraftingTableSummaries()"
                                                          Dense="true"
                                                          Hover="true"
                                                          Class="mud-table-container-no-overflow-y">
                                                    <HeaderContent>
                                                        <MudTh>@LocalizationService.GetTranslation("Name")</MudTh>
                                                        <MudTh>@LocalizationService.GetTranslation("Upgrade")</MudTh>
                                                        <MudTh>@LocalizationService.GetTranslation("PriceCalculator.CostMin.CostMin")</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd>
                                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                                <EcoIcon Item="@GetCraftingTable(context.CraftingTableId)"
                                                                         FallbackIcon="@Icons.Material.Filled.Handyman"
                                                                         Size="24"/>
                                                                <MudText Typo="Typo.body2">@GetCraftingTableLabel(context)</MudText>
                                                            </MudStack>
                                                        </MudTd>
                                                        <MudTd>
                                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                                @if (context.PluginModuleId is Guid pluginModuleId)
                                                                {
                                                                    var pluginModule = GetPluginModule(pluginModuleId);
                                                                    <MudTooltip Text="@(pluginModule?.GetTooltip(LocalizationService) ?? context.PluginModuleName ?? LocalizationService.GetTranslation("PriceCalculator.NoModule"))">
                                                                        <EcoIcon Item="@pluginModule"
                                                                                 FallbackIcon="@MDIIcons.Filled.Cancel"
                                                                                 Size="24"
                                                                                 Class="mt-1"/>
                                                                    </MudTooltip>
                                                                }
                                                                else
                                                                {
                                                                    <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.NoModule")">
                                                                        <EcoIcon Item="@((IHasIconName?)null)"
                                                                                 FallbackIcon="@MDIIcons.Filled.Cancel"
                                                                                 Size="24"
                                                                                 Class="mt-1"/>
                                                                    </MudTooltip>
                                                                }

                                                                @foreach (var skilledPluginModuleId in context.SkilledPluginModuleIds)
                                                                {
                                                                    var skilledPluginModule = GetPluginModule(skilledPluginModuleId);
                                                                    <MudTooltip Text="@(skilledPluginModule?.GetTooltip(LocalizationService) ?? LocalizationService.GetTranslation("PriceCalculator.NoModule"))">
                                                                        <EcoIcon Item="@skilledPluginModule"
                                                                                 Size="24"
                                                                                 Class="has-pluginmodule mt-1"/>
                                                                    </MudTooltip>
                                                                }
                                                            </MudStack>
                                                        </MudTd>
                                                        <MudTd>@FormatDecimal(context.CraftMinuteFee)</MudTd>
                                                    </RowTemplate>
                                                    <NoRecordsContent>
                                                        <MudText Class="pa-2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoCraftingTableData")</MudText>
                                                    </NoRecordsContent>
                                                </MudTable>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="d-flex">
                                        <MudPaper Class="pa-3 flex-grow-1">
                                            <MudStack Spacing="1">
                                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                                                        @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Player2Badge")
                                                    </MudChip>
                                                    <MudText Typo="Typo.body2">@GetSelectedPlayer2ContextTitle()</MudText>
                                                </MudStack>
                                                <MudTable Items="GetSelectedPlayer2CraftingTableSummaries()"
                                                          Dense="true"
                                                          Hover="true"
                                                          Class="mud-table-container-no-overflow-y">
                                                    <HeaderContent>
                                                        <MudTh>@LocalizationService.GetTranslation("Name")</MudTh>
                                                        <MudTh>@LocalizationService.GetTranslation("Upgrade")</MudTh>
                                                        <MudTh>@LocalizationService.GetTranslation("PriceCalculator.CostMin.CostMin")</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd>
                                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                                <EcoIcon Item="@GetCraftingTable(context.CraftingTableId)"
                                                                         FallbackIcon="@Icons.Material.Filled.Handyman"
                                                                         Size="24"/>
                                                                <MudText Typo="Typo.body2">@GetCraftingTableLabel(context)</MudText>
                                                            </MudStack>
                                                        </MudTd>
                                                        <MudTd>
                                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                                                @if (context.PluginModuleId is Guid pluginModuleId)
                                                                {
                                                                    var pluginModule = GetPluginModule(pluginModuleId);
                                                                    <MudTooltip Text="@(pluginModule?.GetTooltip(LocalizationService) ?? context.PluginModuleName ?? LocalizationService.GetTranslation("PriceCalculator.NoModule"))">
                                                                        <EcoIcon Item="@pluginModule"
                                                                                 FallbackIcon="@MDIIcons.Filled.Cancel"
                                                                                 Size="24"
                                                                                 Class="mt-1"/>
                                                                    </MudTooltip>
                                                                }
                                                                else
                                                                {
                                                                    <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.NoModule")">
                                                                        <EcoIcon Item="@((IHasIconName?)null)"
                                                                                 FallbackIcon="@MDIIcons.Filled.Cancel"
                                                                                 Size="24"
                                                                                 Class="mt-1"/>
                                                                    </MudTooltip>
                                                                }

                                                                @foreach (var skilledPluginModuleId in context.SkilledPluginModuleIds)
                                                                {
                                                                    var skilledPluginModule = GetPluginModule(skilledPluginModuleId);
                                                                    <MudTooltip Text="@(skilledPluginModule?.GetTooltip(LocalizationService) ?? LocalizationService.GetTranslation("PriceCalculator.NoModule"))">
                                                                        <EcoIcon Item="@skilledPluginModule"
                                                                                 Size="24"
                                                                                 Class="has-pluginmodule mt-1"/>
                                                                    </MudTooltip>
                                                                }
                                                            </MudStack>
                                                        </MudTd>
                                                        <MudTd>@FormatDecimal(context.CraftMinuteFee)</MudTd>
                                                    </RowTemplate>
                                                    <NoRecordsContent>
                                                        <MudText Class="pa-2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoCraftingTableData")</MudText>
                                                    </NoRecordsContent>
                                                </MudTable>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.PriceOptionsComparison")</MudText>
                                <MudTable Items="GetPriceOptionComparisonRows()" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Option")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Player1Value")</MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Player2Value")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@LocalizationService.GetTranslation(context.OptionTranslationKey)</MudTd>
                                    <MudTd>@context.Player1Value</MudTd>
                                    <MudTd>@context.Player2Value</MudTd>
                                </RowTemplate>
                                </MudTable>

                                <MudStack Row="true"
                                          Wrap="Wrap.Wrap"
                                          Justify="Justify.FlexStart"
                                          AlignItems="AlignItems.Center"
                                          Spacing="2"
                                          Class="mt-2">
                                    <div class="comparison-by-select-container">
                                        <MudSelect T="EconomyComparisonEntity"
                                                   Value="_comparisonBy"
                                                   Label="@LocalizationService.GetTranslation("EconomyViewer.Drilldown.CompareBy")"
                                                   Variant="Variant.Outlined"
                                                   FullWidth="true"
                                                   Class="no-wrap-select"
                                                   ValueChanged="OnComparisonByChanged">
                                            <MudSelectItem T="EconomyComparisonEntity" Value="EconomyComparisonEntity.Item">@LocalizationService.GetTranslation("EconomyViewer.Groups.Item")</MudSelectItem>
                                            <MudSelectItem T="EconomyComparisonEntity" Value="EconomyComparisonEntity.Recipe">@LocalizationService.GetTranslation("EconomyViewer.Groups.Recipe")</MudSelectItem>
                                            <MudSelectItem T="EconomyComparisonEntity" Value="EconomyComparisonEntity.Skill">@LocalizationService.GetTranslation("EconomyViewer.Groups.Skill")</MudSelectItem>
                                        </MudSelect>
                                    </div>
                                    <MudSwitch T="bool"
                                               Value="_showComparisonIncompleteRows"
                                               ValueChanged="OnShowComparisonIncompleteRowsChanged"
                                               Color="@(_showComparisonIncompleteRows ? Color.Primary : Color.Default)"
                                               Label="@LocalizationService.GetTranslation("EconomyViewer.Filters.ShowIncompleteRows")"/>
                                </MudStack>
                                <MudText Typo="Typo.subtitle2">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.ComparisonTable")</MudText>
                                <MudTable Items="_drilldown.ComparisonRows" Filter="new Func<EconomyPlayerComparisonRow, bool>(FilterComparisonRow)" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>
                                        <MudStack Row AlignItems="AlignItems.Center">
                                            <MudTableSortLabel InitialDirection="SortDirection.Ascending"
                                                               SortBy="new Func<EconomyPlayerComparisonRow, object>(row => GetComparisonRowLabel(row))">
                                                @LocalizationService.GetTranslation("EconomyViewer.Columns.Entity")
                                            </MudTableSortLabel>
                                            <MudTextField T="string"
                                                          @bind-Value="_comparisonSearch"
                                                          Immediate
                                                          Placeholder="@LocalizationService.GetTranslation("Search")"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                                          IconSize="Size.Medium"
                                                          Class="mt-0" />
                                        </MudStack>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.Player1Value ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Player1Value")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.Player2Value ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Player2Value")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.DeltaAbs ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.DeltaAbs")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>
                                        <MudTableSortLabel SortBy="new Func<EconomyPlayerComparisonRow, object>(row => row.DeltaPct ?? decimal.MaxValue)">
                                            @LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.DeltaPct")
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>@LocalizationService.GetTranslation("EconomyViewer.Drilldown.Columns.Status")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <EcoIcon Item="@GetComparisonRowIcon(context)"
                                                     FallbackIcon="@GetComparisonRowFallbackIcon(context)"
                                                     Size="24"/>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@GetComparisonRowLabel(context)</MudText>
                                                @if (!string.IsNullOrWhiteSpace(GetComparisonRowSubLabel(context)))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetComparisonRowSubLabel(context)</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd>@FormatDecimal(context.Player1Value)</MudTd>
                                    <MudTd>@FormatDecimal(context.Player2Value)</MudTd>
                                    <MudTd>@FormatSignedDecimal(context.DeltaAbs)</MudTd>
                                    <MudTd>@FormatSignedPercent(context.DeltaPct)</MudTd>
                                    <MudTd>
                                        <MudTooltip Text="@GetComparisonStatusTooltip(context)">
                                            <MudChip T="string" Color="@GetStatusColor(context.Status)" Variant="Variant.Outlined" Size="Size.Small">
                                                @LocalizationService.GetTranslation($"EconomyViewer.Status.{context.Status}")
                                            </MudChip>
                                        </MudTooltip>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Class="pa-4">@LocalizationService.GetTranslation("EconomyViewer.Drilldown.NoComparisonData")</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 200 }"/>
                                </PagerContent>
                                </MudTable>
                            </MudStack>
                        }
                            </MudStack>
                        </MudPaper>
                    </div>
                </div>
            }

            @if (_isHelpModalOpen)
            {
                <div class="economy-help-overlay" @onclick="CloseHelpModal">
                    <div class="economy-help-modal-wrapper" @onclick:stopPropagation="true">
                        <MudPaper Class="economy-help-modal pa-4" Elevation="12">
                            <MudStack Spacing="2">
                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">@LocalizationService.GetTranslation("EconomyViewer.Help.Title")</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Color="Color.Default"
                                                   OnClick="CloseHelpModal"/>
                                </MudStack>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line1")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line2")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line3")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line4")</MudText>
                                <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("EconomyViewer.Help.Line5")</MudText>
                            </MudStack>
                        </MudPaper>
                    </div>
                </div>
            }
    }
</MudContainer>

@code {
    private bool _isLoadingPage = true;
    private bool _isLoadingGlobal;
    private bool _isLoadingDrilldown;
    private bool _isDrilldownOpen;
    private bool _isHelpModalOpen;

    private EconomyGroupBy _groupBy = EconomyGroupBy.Item;
    private string _searchText = string.Empty;
    private bool _showIncompleteRows;
    private bool _showSpreadAsPercent;
    private Guid? _filterSkillId;
    private Guid? _globalFilterUserServerId;

    private Guid? _selectedPlayer1UserServerId;
    private Guid? _selectedPlayer2UserServerId;
    private Guid? _selectedPlayer2DataContextId;
    private Guid? _selectedPlayer1DataContextId;
    private EconomyComparisonEntity _comparisonBy = EconomyComparisonEntity.Item;
    private bool _comparisonOnlyDifferences;
    private bool _comparisonOnlyCommon;
    private bool _showComparisonIncompleteRows;
    private string _comparisonSearch = string.Empty;

    private EconomyGlobalResult _globalResult = new();
    private EconomyPlayerDetailResult? _drilldown;
    private readonly HashSet<string> _expandedGlobalRowKeys = [];

    private List<ItemOrTag> _availableItems = [];
    private List<Recipe> _availableRecipes = [];
    private List<Skill> _availableSkills = [];
    private List<CraftingTable> _availableCraftingTables = [];
    private List<PluginModule> _availablePluginModules = [];
    private List<UserServer> _availablePlayers = [];
    private Dictionary<Guid, ItemOrTag> _itemsById = [];
    private Dictionary<Guid, Recipe> _recipesById = [];
    private Dictionary<Guid, Skill> _skillsById = [];
    private Dictionary<Guid, CraftingTable> _craftingTablesById = [];
    private Dictionary<Guid, PluginModule> _pluginModulesById = [];
    private Dictionary<Guid, ItemOrTag> _recipeProductItemsByRecipeId = [];
    private const string ShowIncompleteRowsStorageKey = "EconomyViewer.ShowIncompleteRows";
    private const string ShowComparisonIncompleteRowsStorageKey = "EconomyViewer.ShowComparisonIncompleteRows";
    private const string ShowSpreadAsPercentStorageKey = "EconomyViewer.ShowSpreadAsPercent";
    private const string DrilldownPlayer2UserServerIdStorageKey = "EconomyViewer.Drilldown.Player2UserServerId";
    private bool CanOpenDrilldown => _availablePlayers.Count > 1;

    protected override void OnInitialized()
    {
        ContextService.OnContextChanged += OnContextChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeAndLoadAsync();
    }

    private async Task InitializeAndLoadAsync()
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null)
        {
            _isLoadingPage = false;
            StateHasChanged();
            return;
        }

        try
        {
            _isLoadingPage = true;
            _showIncompleteRows = await LocalStorageService.GetItem(ShowIncompleteRowsStorageKey) == "True";
            _showComparisonIncompleteRows = await LocalStorageService.GetItem(ShowComparisonIncompleteRowsStorageKey) == "True";
            _showSpreadAsPercent = await LocalStorageService.GetItem(ShowSpreadAsPercentStorageKey) == "True";
            await EnsureServerDataLoadedAsync();
            await InitializeDefaultDrilldownPlayersAsync();
            await LoadGlobalAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadGlobal")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingPage = false;
            StateHasChanged();
        }
    }

    private async Task EnsureServerDataLoadedAsync()
    {
        if (ContextService.CurrentServer is null)
        {
            return;
        }

        if (ContextService.CurrentServerData is null || ContextService.CurrentServerData.Id != ContextService.CurrentServer.Id)
        {
            ContextService.CurrentServerData = await ServerDbService.GetServerWithData(ContextService.CurrentServer.Id);
        }

        _availableItems = ContextService.CurrentServerData.ItemOrTags
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availableRecipes = ContextService.CurrentServerData.Recipes
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        var allSkills = ContextService.CurrentServerData.Skills
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availableSkills = allSkills
            .Where(s => s.Profession is not null)
            .ToList();

        _availableCraftingTables = ContextService.CurrentServerData.CraftingTables
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availablePluginModules = ContextService.CurrentServerData.PluginModules
            .OrderBy(LocalizationService.GetTranslation)
            .ToList();

        _availablePlayers = ContextService.CurrentServer.UserServers
            .OrderBy(us => us.GetPseudo())
            .ToList();

        _itemsById = _availableItems.ToDictionary(i => i.Id);
        _recipesById = _availableRecipes.ToDictionary(r => r.Id);
        _skillsById = allSkills.ToDictionary(s => s.Id);
        _craftingTablesById = _availableCraftingTables.ToDictionary(ct => ct.Id);
        _pluginModulesById = _availablePluginModules.ToDictionary(pm => pm.Id);
        _recipeProductItemsByRecipeId = _availableRecipes
            .Select(recipe => new
            {
                recipe.Id,
                ProductItem = recipe.Elements.FirstOrDefault(e => e.IsProduct())?.ItemOrTag
            })
            .Where(x => x.ProductItem is not null)
            .ToDictionary(x => x.Id, x => x.ProductItem!);
    }

    private async Task InitializeDefaultDrilldownPlayersAsync()
    {
        if (ContextService.CurrentUserServer is null)
        {
            _selectedPlayer1UserServerId = null;
            _selectedPlayer2UserServerId = null;
            return;
        }

        _selectedPlayer1UserServerId = ContextService.CurrentUserServer.Id;

        if (!CanOpenDrilldown)
        {
            _selectedPlayer2UserServerId = null;
            _selectedPlayer1DataContextId = null;
            _selectedPlayer2DataContextId = null;
            _isDrilldownOpen = false;
            return;
        }

        var storedPlayer2 = await LocalStorageService.GetItem(DrilldownPlayer2UserServerIdStorageKey);
        var preferredPlayer2 = Guid.TryParse(storedPlayer2, out var player2UserServerId)
            ? player2UserServerId
            : (Guid?)null;

        _selectedPlayer2UserServerId = ResolvePlayer2Selection(_selectedPlayer1UserServerId.Value, preferredPlayer2);
        await PersistSelectedPlayer2Async(_selectedPlayer2UserServerId);
    }

    private Guid? ResolvePlayer2Selection(Guid player1UserServerId, Guid? preferredPlayer2UserServerId)
    {
        if (preferredPlayer2UserServerId is Guid preferredId
            && preferredId != player1UserServerId
            && _availablePlayers.Any(player => player.Id == preferredId))
        {
            return preferredId;
        }

        return GetFirstDifferentPlayerUserServerId(player1UserServerId);
    }

    private Guid? GetFirstDifferentPlayerUserServerId(Guid player1UserServerId)
    {
        return _availablePlayers
            .Select(player => (Guid?)player.Id)
            .FirstOrDefault(playerId => playerId != player1UserServerId);
    }

    private async Task PersistSelectedPlayer2Async(Guid? player2UserServerId)
    {
        if (player2UserServerId is null)
        {
            await LocalStorageService.RemoveItem(DrilldownPlayer2UserServerIdStorageKey);
            return;
        }

        await LocalStorageService.AddItem(DrilldownPlayer2UserServerIdStorageKey, player2UserServerId.Value.ToString());
    }

    private string GetOpenDrilldownTooltip()
    {
        return CanOpenDrilldown
            ? LocalizationService.GetTranslation("EconomyViewer.Actions.OpenDrilldown")
            : LocalizationService.GetTranslation("EconomyViewer.Drilldown.AtLeastTwoPlayersRequired");
    }

    private async Task LoadGlobalAsync(bool showLoadingIndicator = true)
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentUserServer is null)
        {
            return;
        }

        try
        {
            ResetGlobalRowExpansionState();

            if (showLoadingIndicator)
            {
                _isLoadingGlobal = true;
                StateHasChanged();
            }

            var query = new EconomyGlobalQuery
            {
                ServerId = ContextService.CurrentServer.Id,
                GroupBy = _groupBy,
                SearchText = string.Empty,
                SkillId = _filterSkillId,
                UserServerId = _globalFilterUserServerId,
                SortBy = EconomyGlobalSortBy.Label,
                SortDescending = false,
                Page = 1,
                PageSize = 0
            };

            _globalResult = await EconomyViewerService.GetGlobalAsync(query, ContextService.CurrentUserServer.Id);
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(LocalizationService.GetTranslation("EconomyViewer.Errors.Unauthorized"), Severity.Error);
            _globalResult = new EconomyGlobalResult();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadGlobal")}: {ex.Message}", Severity.Error);
            _globalResult = new EconomyGlobalResult();
        }
        finally
        {
            if (showLoadingIndicator)
            {
                _isLoadingGlobal = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDrilldownAsync(bool showLoadingIndicator = true, bool comparisonRowsOnly = false)
    {
        if (!CanOpenDrilldown
            || ContextService.CurrentServer is null
            || ContextService.CurrentUserServer is null
            || _selectedPlayer1UserServerId is null
            || _selectedPlayer2UserServerId is null
            || _selectedPlayer1UserServerId == _selectedPlayer2UserServerId)
        {
            return;
        }

        try
        {
            if (showLoadingIndicator)
            {
                _isLoadingDrilldown = true;
                StateHasChanged();
            }

            var query = new EconomyPlayerDetailQuery
            {
                ServerId = ContextService.CurrentServer.Id,
                RequestingUserServerId = ContextService.CurrentUserServer.Id,
                Player1UserServerId = _selectedPlayer1UserServerId.Value,
                Player2UserServerId = _selectedPlayer2UserServerId.Value,
                Player1DataContextId = _selectedPlayer1DataContextId,
                Player2DataContextId = _selectedPlayer2DataContextId,
                ComparisonBy = _comparisonBy,
                SortBy = EconomyComparisonSortBy.Entity,
                SortDescending = false,
                SearchText = string.Empty,
                OnlyDifferences = false,
                Page = 1,
                PageSize = 0
            };

            var result = await EconomyViewerService.GetPlayerDetailAsync(query);

            if (comparisonRowsOnly && _drilldown is not null)
            {
                _drilldown.ComparisonRows = result.ComparisonRows;
                _drilldown.TotalComparisonCount = result.TotalComparisonCount;
                _drilldown.Page = result.Page;
                _drilldown.PageSize = result.PageSize;
                _drilldown.GeneratedAtUtc = result.GeneratedAtUtc;
            }
            else
            {
                _drilldown = result;
                _selectedPlayer1DataContextId = _drilldown.SelectedPlayer1DataContextId;
                _selectedPlayer2DataContextId = _drilldown.SelectedPlayer2DataContextId;
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(LocalizationService.GetTranslation("EconomyViewer.Errors.Unauthorized"), Severity.Error);
            if (!comparisonRowsOnly)
            {
                _drilldown = null;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadDrilldown")}: {ex.Message}", Severity.Error);
            if (!comparisonRowsOnly)
            {
                _drilldown = null;
            }
        }
        finally
        {
            if (showLoadingIndicator)
            {
                _isLoadingDrilldown = false;
            }

            StateHasChanged();
        }
    }

    private async Task OnGroupByChanged(EconomyGroupBy value)
    {
        _groupBy = value;
        ResetGlobalRowExpansionState();

        await LoadGlobalAsync();
    }

    private async Task OnGlobalPlayerFilterChanged(Guid? value)
    {
        _globalFilterUserServerId = value;
        await LoadGlobalAsync();
    }

    private async Task OnGlobalSkillFilterChanged(Guid? value)
    {
        _filterSkillId = value;
        await LoadGlobalAsync();
    }

    private async Task ResetGlobalFilters()
    {
        _groupBy = EconomyGroupBy.Item;
        _searchText = string.Empty;
        _showIncompleteRows = false;
        _filterSkillId = null;
        _globalFilterUserServerId = null;
        await LocalStorageService.AddItem(ShowIncompleteRowsStorageKey, bool.FalseString);
        await LoadGlobalAsync();
    }

    private bool FilterGlobalRow(EconomyGlobalRow row)
    {
        if (!_showIncompleteRows && !IsCompleteEconomyRow(row))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var search = _searchText.Trim();

        if (GetGlobalRowLabel(row).Contains(search, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var subLabel = GetGlobalRowSubLabel(row);
        return !string.IsNullOrWhiteSpace(subLabel) && subLabel.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private bool ShouldShowGlobalExpansionColumn()
    {
        return _groupBy is EconomyGroupBy.Item or EconomyGroupBy.Recipe or EconomyGroupBy.Skill;
    }

    private bool CanExpandGlobalRow(EconomyGlobalRow row)
    {
        return ShouldShowGlobalExpansionColumn() && row.PlayerDetails.Count > 1;
    }

    private bool IsGlobalRowExpanded(EconomyGlobalRow row)
    {
        return _expandedGlobalRowKeys.Contains(row.GroupKey);
